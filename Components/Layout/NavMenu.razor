<style>
    /* CSS WAS GLUING THE BOXES DROPDOWN OPEN, THIS IS AN OVERRIDE UNTIL FURTHER NOTICE */
    .mud-nav-group-items {
        display: inherit; 
    }
    
    
    .mud-nav-group-header {
        height: auto !important;
        min-height: 3rem;
    }
</style>



@implements IDisposable
@inject NavigationManager NavigationManager

<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
    
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="dashboard" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
        </Authorized>
    </AuthorizeView>

    <MudNavLink Href="products" Icon="@Icons.Material.Filled.Storefront">Catalog</MudNavLink>
    <MudNavLink Href="inventory" Icon="@Icons.Material.Filled.Inventory">Inventory</MudNavLink>
    <MudNavLink Href="/locations" Icon="@Icons.Material.Filled.LocationOn">Locations</MudNavLink>
    <MudNavLink Href="sales/create" Icon="@Icons.Material.Filled.PointOfSale">Process Sale</MudNavLink>
    
    <MudNavGroup Title="Boxes" Icon="@Icons.Material.Filled.Archive" >
        <MudNavLink Href="/inventory/transfer/create" Icon="@Icons.Material.Filled.AddBox">Pack a Box</MudNavLink>
        <MudNavLink Href="/inventory/transfers" Icon="@Icons.Material.Filled.ListAlt">History</MudNavLink>
    </MudNavGroup>

    <MudDivider Class="my-2" />

    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="Account/Manage" Icon="@Icons.Material.Filled.Person">@context.User.Identity?.Name</MudNavLink>
            <div class="px-4 py-2">
                <form action="Account/Logout" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                    <MudButton ButtonType="ButtonType.Submit" 
                               Variant="Variant.Text" 
                               Color="Color.Inherit" 
                               StartIcon="@Icons.Material.Filled.Logout"
                               FullWidth="true"
                               Style="justify-content: flex-start; text-transform: none;">
                        Logout
                    </MudButton>
                </form>
            </div>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="Account/Register" Icon="@Icons.Material.Filled.PersonAdd">Register</MudNavLink>
            <MudNavLink Href="Account/Login" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>

    <AuthorizeView Roles="Admin">
        <Authorized>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.caption" Class="px-4 mud-text-secondary">ADMIN</MudText>
            <MudNavLink Href="admin/users" Icon="@Icons.Material.Filled.People">User Management</MudNavLink>
            <MudNavLink Href="admin/storage" Icon="@Icons.Material.Filled.CloudUpload">Storage Admin</MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
