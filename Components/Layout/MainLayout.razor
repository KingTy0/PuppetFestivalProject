@inherits LayoutComponentBase

<MudThemeProvider Theme="_BackstageColorPallete"/>
<MudPopoverProvider @rendermode="InteractiveServer" />
<MudDialogProvider @rendermode="InteractiveServer" />
<MudSnackbarProvider @rendermode="InteractiveServer" />

<MudLayout>
    <MudAppBar Elevation="4">
        <button onclick="toggleDrawer()" 
                style="background:transparent; border:none; cursor:pointer; padding:8px; color:white; display:flex; align-items:center;">
            <span class="material-icons">menu</span>
        </button>
        <MudText Typo="Typo.h6" Class="ml-3">PuppetFestAPP.Web</MudText>
        <MudSpacer />
    </MudAppBar>

    <MudDrawer Open="true"
               Anchor="Anchor.Left"
               Elevation="1"
               ClipMode="DrawerClipMode.Always"
               Breakpoint="Breakpoint.Md">
        <NavMenu @rendermode="InteractiveServer" />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private MudTheme _BackstageColorPallete = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#5D1E21",
            PrimaryDarken = "#4D191C",
            PrimaryLighten = "#AD383E",
            Secondary = "#154230",
            SecondaryDarken = "#0C271C",
            SecondaryLighten = "#257450",
            Tertiary = "#A6824A",
            TertiaryDarken = "#7B6137",
            TertiaryLighten = "#C0A272",
            HoverOpacity = 0.06,
            Black = "#101111",
            White = "#FFFFFF",
            LinesDefault = "#9E9E9E",
            LinesInputs = "#BDBDBD",
            Divider = "#E0E0E0",
            DrawerBackground = "#5D1E21",
            DrawerText = "#FFFFFF",
            DrawerIcon = "#FFFFFF",
            AppbarBackground = "#5D1E21",
            AppbarText = "#FFFFFF",
            Info = "#2196F3",
            Success = "#00C853",
            Warning = "#FF9800",
            Error = "#F44336"
        },
    };
}