@page "/splash"
@inject NavigationManager NavigationManager

<PageTitle>Welcome</PageTitle>

<div id="splash-container" class="backstage-splash-container" onclick="triggerFade()">
    
    @* --- Spotlight Background --- *@
    <object data="Images/spotlight-anim-scale10.svg?t=@_timestamp" type="image/svg+xml" class="spotlight-logo"></object>

    @* --- Left Curtain --- *@
    <div class="curtain-group left-side">
        <object data="Images/L-bottom-anim-desktop-position-fixed.svg?t=@_timestamp" 
                type="image/svg+xml" class="curtain-part anim"></object>
        <object data="Images/L-top-static-desktop-clean.svg?t=@_timestamp" 
                type="image/svg+xml" class="curtain-part static-top"></object>
    </div>

    @* --- Right Curtain --- *@
    <div class="curtain-group right-side">
        <object data="Images/R-bottom-anim-desktop-position-fixed-v2.svg?t=@_timestamp" 
                type="image/svg+xml" class="curtain-part anim"></object>
        <object data="Images/R-top-static-desktop-clean.svg?t=@_timestamp" 
                type="image/svg+xml" class="curtain-part static-top"></object>
    </div>

</div>

<script>
    var _navigating = false;

    function triggerFade() {
        if (_navigating) return;
        _navigating = true;

        var el = document.getElementById('splash-container');
        el.classList.add('fade-out');

        setTimeout(function () {
            window.location.href = '/';
        }, 0);
    }
</script>

<style>
    html, body, #app {
        height: 100%;
        margin: 0;
        padding: 0;
        overflow: hidden;
    }

    .backstage-splash-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: #4d191d;
        z-index: 10000;
        overflow: hidden;
        transition: opacity 0.5s ease-out;
        cursor: pointer;
        pointer-events: auto;
    }

    .fade-out { opacity: 0; pointer-events: none; }

    .curtain-group {
        position: absolute;
        top: 0;
        height: 100vh;
        width: 100vw;
        pointer-events: none;
    }

    .left-side  { left: 0;  z-index: 10001; }
    .right-side { right: 0; z-index: 10001; }

    .curtain-part {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        object-fit: fill;
        display: block;
        pointer-events: none;
    }

    .anim       { z-index: 10002; }
    .static-top { z-index: 10003; }

    .spotlight-logo {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100vw;
        height: 100vh;
        object-fit: cover;
        z-index: 10000;
        pointer-events: none;
    }
</style>

@code {
    private long _timestamp = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
}