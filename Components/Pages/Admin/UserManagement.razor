@code {
    // ── Component State ──
    // These private fields hold the page's data. Blazor automatically
    // re-renders the page whenever a state change is detected (e.g.,
    // after an @onclick handler finishes).
    private List<userviewmodel> users = new();
    private string newUserEmail = "";
    private string newUserPassword = "";
    private string newUserRole = AppRoles.SalesStaff; // default selection for the "Role" dropdown in the "Create New User"
    private string statusMessage = "";
    private string statusCssClass = "";

    /// <summary>
    /// Called automatically by Blazor when the component first loads.
    /// Populates the user list from the database.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    /// <summary>
    /// Fetches all users from the database and builds the view model list.
    /// Creates a fresh DI scope so the UserManager and its underlying
    /// DbContext are short-lived and disposed after the query completes.
    /// </summary>
    private async Task LoadUsers()
    {
        users.Clear();

        // ── Create a fresh DI scope ──
        // "using var" ensures the scope (and its DbContext) is disposed
        // when this method exits. This prevents stale entity tracking
        // and avoids DbContext thread-safety issues.
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider
            .GetRequiredService<usermanager<applicationuser>>();

        // UserManager.Users returns an IQueryable<applicationuser>.
        // .ToList() executes the SQL query and loads all users into memory.
        foreach (var user in userManager.Users.ToList())
        {
            // GetRolesAsync queries the AspNetUserRoles join table
            // for this specific user and returns their role names.
            var roles = await userManager.GetRolesAsync(user);

            users.Add(new UserViewModel
            {
                Id = user.Id,
                Email = user.Email ?? "",
                Roles = roles.ToList(),
                EmailConfirmed = user.EmailConfirmed,
                SelectedNewRole = AppRoles.SalesStaff //default selection for the "Add Role" dropdown in the "All users" table
            });
        }
    }

    /// <summary>
    /// Creates a new user account with the specified email, password,
    /// and initial role. Called when the admin clicks "Create User".
    /// Uses its own DI scope for a fresh DbContext.
    /// </summary>
    private async Task CreateUser()
    {
        if (string.IsNullOrWhiteSpace(newUserEmail) ||
            string.IsNullOrWhiteSpace(newUserPassword))
        {
            statusMessage = "Email and password are required.";
            statusCssClass = "alert-warning";
            return;
        }

        // ── Fresh scope for this operation ──
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider
            .GetRequiredService<usermanager<applicationuser>>();

        var user = new ApplicationUser
        {
            UserName = newUserEmail,
            Email = newUserEmail,
            EmailConfirmed = true // Admin-created users skip email verification
        };

        // CreateAsync validates the password against the configured rules
        // (length, uppercase, digit, etc.) and hashes it before saving.
        var result = await userManager.CreateAsync(user, newUserPassword);

        if (result.Succeeded)
        {
            await userManager.AddToRoleAsync(user, newUserRole);
            statusMessage = $"User {newUserEmail} created " +
                            $"with role {newUserRole}.";
            statusCssClass = "alert-success";
            newUserEmail = "";
            newUserPassword = "";
            await LoadUsers(); // Refresh the displayed list
        }
        else
        {
            // Identity provides specific error messages like
            // "Passwords must have at least one uppercase letter"
            statusMessage = "Error: " + string.Join(", ",
                result.Errors.Select(e => e.Description));
            statusCssClass = "alert-danger";
        }
    }

    /// <summary>
    /// Adds an additional role to an existing user.
    /// Users can have multiple roles simultaneously.
    /// Uses its own DI scope for a fresh DbContext.
    /// </summary>
    private async Task AddRoleToUser(UserViewModel userVm)
    {
        // ── Fresh scope for this operation ──
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider
            .GetRequiredService<usermanager<applicationuser>>();

        var user = await userManager.FindByIdAsync(userVm.Id);
        if (user == null) return;

        // Check if they already have this role to avoid duplicates
        if (!await userManager.IsInRoleAsync(user, userVm.SelectedNewRole))
        {
            await userManager.AddToRoleAsync(user, userVm.SelectedNewRole);
            statusMessage = $"Added role {userVm.SelectedNewRole} " +
                            $"to {user.Email}.";
            statusCssClass = "alert-success";
            await LoadUsers();
        }
        else
        {
            statusMessage = $"{user.Email} already has role " +
                            $"{userVm.SelectedNewRole}.";
            statusCssClass = "alert-info";
        }
    }

    /// <summary>
    /// Permanently deletes a user account. The admin@puppetfest.local
    /// account is protected from deletion by the disabled button in the UI.
    /// Uses its own DI scope for a fresh DbContext.
    /// </summary>
    private async Task DeleteUser(UserViewModel userVm)
    {
        // ── Fresh scope for this operation ──
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider
            .GetRequiredService<usermanager<applicationuser>>();

        var user = await userManager.FindByIdAsync(userVm.Id);
        if (user == null) return;

        var result = await userManager.DeleteAsync(user);
        if (result.Succeeded)
        {
            statusMessage = $"User {userVm.Email} deleted.";
            statusCssClass = "alert-success";
            await LoadUsers();
        }
        else
        {
            statusMessage = "Error deleting user: " +
                string.Join(", ",
                    result.Errors.Select(e => e.Description));
            statusCssClass = "alert-danger";
        }
    }

    /// <summary>
    /// View model for displaying a user in the table. We use a separate
    /// view model (instead of ApplicationUser directly) because we need
    /// to include the roles list and a UI-only field (SelectedNewRole)
    /// that don't belong on the database entity.
    /// </summary>
    private class UserViewModel
    {
        public string Id { get; set; } = "";
        public string Email { get; set; } = "";
        public List<string> Roles { get; set; } = new();
        public bool EmailConfirmed { get; set; }
        public string SelectedNewRole { get; set; } = AppRoles.SalesStaff;
    }
}</string></usermanager<applicationuser></usermanager<applicationuser></usermanager<applicationuser></applicationuser></usermanager<applicationuser></userviewmodel>