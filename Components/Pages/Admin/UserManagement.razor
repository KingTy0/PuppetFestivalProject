@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using PuppetFestAPP.Web.Data
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IServiceProvider ServiceProvider
@inject NavigationManager NavigationManager

<PageTitle>User Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudText Class="my-8">
        <h1>User Management</h1>
    </MudText>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <MudAlert Severity="@statusSeverity" Variant="Variant.Text" Class="mb-4" OnClose="@(() => statusMessage = "")">
            @statusMessage
        </MudAlert>
    }

    <MudButton Href="/admin/users/create" 
                StartIcon="@Icons.Material.Filled.Add"
                Variant="Variant.Filled" 
                Color="Color.Primary"
                FullWidth="true"
                Size="Size.Large"
                Class="mb-8">
        Create a User
    </MudButton>

    <MudText Class="mb-2">
        <h3>All Users (@users.Count)</h3>
    </MudText>
    <MudDivider Class="mb-5"></MudDivider>

    
    <MudExpansionPanels MultiExpansion="true" Class="mb-4">
        @* Admin Role -- Expansion Panel *@
        <MudExpansionPanel Text="@($"Admin ({Admins.Count()})")" Expanded="true" Class="px-1">
            <MudList T="string" >
                @foreach (var admin in Admins)
                {
                    <MudListItem Class="px-1">
                        <div class="d-flex align-center justify-space-between">
                            <MudText Typo="Typo.body1"><p>@admin.Email</p></MudText>
                            <div>
                                <MudTooltip Text="Edit User">
                                    <MudIconButton OnClick="@(() => NavigationManager.NavigateTo($"/admin/users/{admin.Id}/edit"))"
                                    Icon="@Icons.Material.Filled.Edit"
                                    Variant="Variant.Filled" 
                                    Color="Color.Default" 
                                    Class="mr-2"
                                    />
                                </MudTooltip>
                                <MudTooltip Text="Delete User">
                                    <MudIconButton OnClick="@(() => ConfirmDelete(admin))"
                                    Disabled="@(admin.Email == "admin@puppetfest.local")"
                                    Icon="@Icons.Material.Filled.Delete" 
                                    Variant="Variant.Filled" 
                                    Color="Color.Default" 
                                    Class="mr-2" />
                                </MudTooltip>
                            </div>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        </MudExpansionPanel>

        @* Inventory Manager Role -- Expansion Panel *@
        <MudExpansionPanel Text="@($"Inventory Manager ({InventoryManagers.Count()})")" Expanded="true">
            <MudList T="string">
                @foreach (var im in InventoryManagers)
                {
                    <MudListItem Class="px-1">
                        <div class="d-flex align-center justify-space-between">
                            <MudText Typo="Typo.body1"><p>@im.Email</p></MudText>
                            <div>
                                <MudTooltip Text="Edit User">
                                    <MudIconButton OnClick="@(() => NavigationManager.NavigateTo($"/admin/users/{im.Id}/edit"))"
                                    Icon="@Icons.Material.Filled.Edit"
                                    Variant="Variant.Filled" 
                                    Color="Color.Default" 
                                    Class="mr-2"
                                    />
                                </MudTooltip>
                                <MudTooltip Text="Delete User">
                                    <MudIconButton OnClick="@(() => ConfirmDelete(im))"
                                    Disabled="@(im.Email == "admin@puppetfest.local")"
                                    Icon="@Icons.Material.Filled.Delete" 
                                    Variant="Variant.Filled" 
                                    Color="Color.Default" 
                                    Class="mr-2" />
                                </MudTooltip>
                            </div>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        </MudExpansionPanel>

        @* Sales Staff Role -- Expansion Panel *@
        <MudExpansionPanel Text="@($"Sales Staff ({SalesStaffs.Count()})")" Expanded="true">
            <MudList T="string">
                @foreach (var ss in SalesStaffs)
                {
                    <MudListItem Class="px-1">
                        <div class="d-flex align-center justify-space-between">
                            <MudText Typo="Typo.body1"><p>@ss.Email</p></MudText>
                            <div>
                                <MudTooltip Text="Edit User">
                                    <MudIconButton OnClick="@(() => NavigationManager.NavigateTo($"/admin/users/{ss.Id}/edit"))"
                                    Icon="@Icons.Material.Filled.Edit"
                                    Variant="Variant.Filled" 
                                    Color="Color.Default" 
                                    Class="mr-2"
                                    />
                                </MudTooltip>
                                <MudTooltip Text="Delete User">
                                    <MudIconButton OnClick="@(() => ConfirmDelete(ss))"
                                    Disabled="@(ss.Email == "admin@puppetfest.local")"
                                    Icon="@Icons.Material.Filled.Delete" 
                                    Variant="Variant.Filled" 
                                    Color="Color.Default" 
                                    Class="mr-2" />
                                </MudTooltip>
                            </div>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        </MudExpansionPanel>

        @* Driver Role -- Expansion Panel *@
    </MudExpansionPanels>


    @* Confirmation Popup *@
    @if (showDeleteConfirm && userPendingDelete is not null)
    {
        @* Darkened overlay *@
        <div @onclick="CancelDelete" style="
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1000;">
        </div>

        @* Popup *@
        <div Class="popup">
            <MudCard Elevation="6">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Large" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText>
                            <h3>Delete User</h3>
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>

                <MudCardContent Class="px-4 pt-0 pb-2">
                    <MudText>
                        <p Class="body-1">Are you sure you want to delete <strong>@userPendingDelete.Email</strong>?</p>
                    </MudText>
                    <MudText>
                        <p Class="body-2">This action cannot be undone.</p>
                    </MudText>
                </MudCardContent>

                <MudCardActions Class="d-flex justify-space-between px-4 py-4">
                    <MudButton OnClick="ExecuteDelete"
                            StartIcon="@Icons.Material.Filled.Delete"
                            Variant="Variant.Filled"
                            Color="Color.Primary"
                            FullWidth
                            Class="mr-4"
                            >
                        Delete
                    </MudButton>
                    <MudButton OnClick="CancelDelete"
                            Variant="Variant.Filled"
                            Color="Color.Default"
                            FullWidth
                            >
                        Cancel
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </div>
    }

    @* <MudTable Items="@users" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1">
        <ToolBarContent>
            <MudText Typo="Typo.h6">All Users (@users.Count)</MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Email</MudTh>
            <MudTh>Roles</MudTh>
            <MudTh>Status</MudTh> =
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Roles">
                @foreach (var role in context.Roles)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Class="me-1">@role</MudChip>
                }
            </MudTd>

            <MudTd DataLabel="Status">
                @if (context.EmailConfirmed)
                {
                    <MudText Color="Color.Success">✓ Confirmed</MudText>
                }
                else
                {
                    <MudText Color="Color.Default">Pending</MudText>
                }
            </MudTd> 

            <MudTd DataLabel="Actions">
                <MudStack Row="true" Spacing="1">
                    <MudSelect @bind-Value="context.SelectedNewRole" Margin="Margin.Dense" Dense="true" Style="width:120px">
                        @foreach (var role in AppRoles.AllRoles)
                        {
                            <MudSelectItem Value="@role">@role</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => AddRoleToUser(context))">+ Role</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" 
                               Disabled="@(context.Email == "admin@puppetfest.local")"
                               OnClick="@(() => DeleteUser(context))">Delete</MudButton>
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable> *@
    
</MudContainer>


@code {
    private List<UserViewModel> users = new();
    private string statusMessage = "";
    private string statusCssClass = "";

    // For delete confirmation popup
    private bool showDeleteConfirm = false;
    private UserViewModel? userPendingDelete = null; 

    // Filters for roles
    private IEnumerable<UserViewModel> Admins =>
        users?.Where(u => u.Roles.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase)))
        ?? Enumerable.Empty<UserViewModel>();
    
    private IEnumerable<UserViewModel> InventoryManagers =>
        users?.Where(u => u.Roles.Any(r => r.Equals("InventoryManager", StringComparison.OrdinalIgnoreCase)))
        ?? Enumerable.Empty<UserViewModel>();

    private IEnumerable<UserViewModel> SalesStaffs =>
        users?.Where(u => u.Roles.Any(r => r.Equals("SalesStaff", StringComparison.OrdinalIgnoreCase)))
        ?? Enumerable.Empty<UserViewModel>();

    // Status message switches
    private Severity statusSeverity => statusCssClass switch {
        "alert-success" => Severity.Success,
        "alert-danger" => Severity.Error,
        "alert-warning" => Severity.Warning,
        _ => Severity.Info
    };

    protected override async Task OnInitializedAsync() => await LoadUsers();

    private async Task LoadUsers() {
        users.Clear();
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        
        foreach (var user in userManager.Users.ToList()) {
            var roles = await userManager.GetRolesAsync(user);
            users.Add(new UserViewModel {
                Id = user.Id,
                Email = user.Email ?? "",
                Roles = roles.ToList(),
                EmailConfirmed = user.EmailConfirmed
            });
        }
    }

    private async Task AddRoleToUser(UserViewModel userVm) {
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        var user = await userManager.FindByIdAsync(userVm.Id);
        if (user != null && !await userManager.IsInRoleAsync(user, userVm.SelectedNewRole)) {
            await userManager.AddToRoleAsync(user, userVm.SelectedNewRole);
            statusMessage = $"Added {userVm.SelectedNewRole} to {user.Email}.";
            statusCssClass = "alert-success";
            await LoadUsers();
        }
    }

    private async Task DeleteUser(UserViewModel userVm) {
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        var user = await userManager.FindByIdAsync(userVm.Id);
        if (user != null) {
            var result = await userManager.DeleteAsync(user);
            if (result.Succeeded) { statusMessage = "User deleted."; statusCssClass = "alert-success"; await LoadUsers(); }
        }
    }

    // Helper methods for delete confirmation
    // Opens popup
    private void ConfirmDelete(UserViewModel user)
    {
        userPendingDelete = user;
        showDeleteConfirm = true; 
    }

    private async Task ExecuteDelete()
    {
        if (userPendingDelete is null) return; 

        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        var user = await userManager.FindByIdAsync(userPendingDelete.Id);
        if (user != null)
        {
            var result = await userManager.DeleteAsync(user);
            if (result.Succeeded)
            {
                statusMessage = $"User {userPendingDelete.Email} has been deleted.";
                statusCssClass = "alert-success";
                await LoadUsers();
            }
        }
        CancelDelete();     
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        userPendingDelete = null; 
    }

    private class UserViewModel {
        public string Id { get; set; } = "";
        public string Email { get; set; } = "";
        public List<string> Roles { get; set; } = new();
        public bool EmailConfirmed { get; set; }
        public string SelectedNewRole { get; set; } = AppRoles.SalesStaff;
    }
}
