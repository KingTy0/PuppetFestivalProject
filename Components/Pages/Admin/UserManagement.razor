@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using PuppetFestAPP.Web.Data
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IServiceProvider ServiceProvider

<PageTitle>User Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">User Management</MudText>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <MudAlert Severity="@statusSeverity" Variant="Variant.Filled" Class="mb-4" OnClose="@(() => statusMessage = "")">
            @statusMessage
        </MudAlert>
    }

    @* ── Create New User Form ── *@
    <MudPaper Elevation="1" Class="pa-4 mb-6">
        <MudText Typo="Typo.h6" Class="mb-4">Create New User</MudText>
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="newUserEmail" Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="newUserPassword" Label="Password" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect @bind-Value="newUserRole" Label="Role" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var role in AppRoles.AllRoles)
                    {
                        <MudSelectItem Value="@role">@role</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="CreateUser">Create User</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* ── User List Table ── *@
    <MudTable Items="@users" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1">
        <ToolBarContent>
            <MudText Typo="Typo.h6">All Users (@users.Count)</MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Email</MudTh>
            <MudTh>Roles</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Roles">
                @foreach (var role in context.Roles)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Class="me-1">@role</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Status">
                @if (context.EmailConfirmed)
                {
                    <MudText Color="Color.Success">✓ Confirmed</MudText>
                }
                else
                {
                    <MudText Color="Color.Default">Pending</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudStack Row="true" Spacing="1">
                    <MudSelect @bind-Value="context.SelectedNewRole" Margin="Margin.Dense" Dense="true" Style="width:120px">
                        @foreach (var role in AppRoles.AllRoles)
                        {
                            <MudSelectItem Value="@role">@role</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => AddRoleToUser(context))">+ Role</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" 
                               Disabled="@(context.Email == "admin@puppetfest.local")"
                               OnClick="@(() => DeleteUser(context))">Delete</MudButton>
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@code {
    private List<UserViewModel> users = new();
    private string newUserEmail = "";
    private string newUserPassword = "";
    private string newUserRole = AppRoles.SalesStaff;
    private string statusMessage = "";
    private string statusCssClass = "";

    private Severity statusSeverity => statusCssClass switch {
        "alert-success" => Severity.Success,
        "alert-danger" => Severity.Error,
        "alert-warning" => Severity.Warning,
        _ => Severity.Info
    };

    protected override async Task OnInitializedAsync() => await LoadUsers();

    private async Task LoadUsers() {
        users.Clear();
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        
        foreach (var user in userManager.Users.ToList()) {
            var roles = await userManager.GetRolesAsync(user);
            users.Add(new UserViewModel {
                Id = user.Id,
                Email = user.Email ?? "",
                Roles = roles.ToList(),
                EmailConfirmed = user.EmailConfirmed
            });
        }
    }

    private async Task CreateUser() {
        if (string.IsNullOrWhiteSpace(newUserEmail) || string.IsNullOrWhiteSpace(newUserPassword)) {
            statusMessage = "Email and password are required.";
            statusCssClass = "alert-warning";
            return;
        }
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        var user = new ApplicationUser { UserName = newUserEmail, Email = newUserEmail, EmailConfirmed = true };
        var result = await userManager.CreateAsync(user, newUserPassword);
        if (result.Succeeded) {
            await userManager.AddToRoleAsync(user, newUserRole);
            statusMessage = $"User {newUserEmail} created.";
            statusCssClass = "alert-success";
            newUserEmail = ""; newUserPassword = "";
            await LoadUsers();
        } else {
            statusMessage = "Error: " + string.Join(", ", result.Errors.Select(e => e.Description));
            statusCssClass = "alert-danger";
        }
    }

    private async Task AddRoleToUser(UserViewModel userVm) {
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        var user = await userManager.FindByIdAsync(userVm.Id);
        if (user != null && !await userManager.IsInRoleAsync(user, userVm.SelectedNewRole)) {
            await userManager.AddToRoleAsync(user, userVm.SelectedNewRole);
            statusMessage = $"Added {userVm.SelectedNewRole} to {user.Email}.";
            statusCssClass = "alert-success";
            await LoadUsers();
        }
    }

    private async Task DeleteUser(UserViewModel userVm) {
        using var scope = ServiceProvider.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        var user = await userManager.FindByIdAsync(userVm.Id);
        if (user != null) {
            var result = await userManager.DeleteAsync(user);
            if (result.Succeeded) { statusMessage = "User deleted."; statusCssClass = "alert-success"; await LoadUsers(); }
        }
    }

    private class UserViewModel {
        public string Id { get; set; } = "";
        public string Email { get; set; } = "";
        public List<string> Roles { get; set; } = new();
        public bool EmailConfirmed { get; set; }
        public string SelectedNewRole { get; set; } = AppRoles.SalesStaff;
    }
}
