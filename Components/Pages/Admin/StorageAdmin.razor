@code {
    // ── Component state ──
    private bool isRunning; // True while a backup is in progress
    private bool isRestoring; // True while a restore is in progress
    private string resultMessage = "";
    private string resultCssClass = "";

    /// <summary>
    /// Triggers a backup through the queue and waits for completion.
    /// Uses RunBackupAndWaitAsync (not EnqueueBackup) so the UI
    /// spinner stays active until the backup actually finishes.
    /// </summary>
    private async Task RunBackup()
    {
        isRunning = true;
        resultMessage = "";
        try
        {
            var blobName = await BackupQueue.RunBackupAndWaitAsync();
            if (blobName != null)
            {
                resultMessage =
                    $"Backup successful! Saved as: {blobName}";
                resultCssClass = "alert-success";
            }
            else
            {
                resultMessage =
                    "Backup skipped — another backup is already running.";
                resultCssClass = "alert-info";
            }
        }
        catch (Exception ex)
        {
            resultMessage = $"Backup failed: {ex.Message}";
            resultCssClass = "alert-danger";
        }
        finally
        {
            isRunning = false;
        }
    }

    /// <summary>
    /// Downloads the most recent backup blob and overwrites the local
    /// database. This is a destructive operation — active sessions will
    /// see errors until the app is restarted.
    /// </summary>
    private async Task RunRestore()
    {
        isRestoring = true;
        resultMessage = "";
        try
        {
            var blobName = await BackupService.RestoreLatestAsync();
            resultMessage = $"Restore successful from: {blobName}. " +
                "Please restart the application for changes to " +
                "take full effect.";
            resultCssClass = "alert-success";
        }
        catch (Exception ex)
        {
            resultMessage = $"Restore failed: {ex.Message}";
            resultCssClass = "alert-danger";
        }
        finally
        {
            isRestoring = false;
        }
    }
}