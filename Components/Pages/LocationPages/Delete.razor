@page "/locations/delete/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Delete Location</PageTitle>

<div class="container mt-4">
    <h1>Delete Location</h1>

    @if (Location == null)
    {
        <div class="alert alert-info">Loading...</div>
    }
    else
    {
        <div class="alert alert-danger">
            <h4>Are you sure you want to delete this?</h4>
            <p><strong>Name:</strong> @Location.Name</p>
            <p><strong>Address:</strong> @Location.Address</p>
        </div>

        @if (HasDependencies)
        {
            <div class="alert alert-warning">
                <strong>Cannot Delete:</strong> This location has stock or transfer records associated with it. 
                You should mark it as <strong>Inactive</strong> instead.
            </div>
        }

        <div class="mt-4">
            <button class="btn btn-danger" @onclick="ConfirmDelete" disabled="@HasDependencies">
                Permanently Delete
            </button>
            <a href="/locations" class="btn btn-secondary">Cancel</a>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private Location? Location;
    private bool HasDependencies;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Location = await context.Locations.FindAsync(Id);

        if (Location != null)
        {
            // Check if there is any stock currently sitting in this location
            var stockCount = await context.ProductLocations.AnyAsync(pl => pl.LocationId == Id);
            
            // Check if this location is used in any transfer boxes
            var transferCount = await context.StockTransferBoxes.AnyAsync(b => b.FromLocationId == Id || b.ToLocationId == Id);

            HasDependencies = stockCount || transferCount;
        }
    }

    private async Task ConfirmDelete()
    {
        if (HasDependencies) return;

        using var context = await DbFactory.CreateDbContextAsync();
        if (Location != null)
        {
            context.Locations.Remove(Location);
            await context.SaveChangesAsync();
        }
        
        Navigation.NavigateTo("/locations");
    }
}