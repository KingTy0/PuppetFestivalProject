@code {
    [Parameter] public int Id { get; set; }
    private Location? Location;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Location = await context.Locations.FindAsync(Id);
    }

    private async Task UpdateLocation()
    {
        if (Location == null) return;

        using var context = await DbFactory.CreateDbContextAsync();
        
        // 1. If name is blank, don't save
        if (string.IsNullOrWhiteSpace(Location.Name)) return;

        // 2. THE HACK: If address is empty, give it a space string " " 
        // to bypass the [Required] attribute in your database model.
        if (string.IsNullOrWhiteSpace(Location.Address))
        {
            Location.Address = " "; 
        }

        context.Locations.Update(Location);
        await context.SaveChangesAsync();
        
        Navigation.NavigateTo("/Locations");
    }
}</ApplicationDbContext>