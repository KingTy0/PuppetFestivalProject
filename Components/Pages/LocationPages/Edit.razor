@page "/locations/edit/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Edit Location</PageTitle>

<div class="container mt-4">
    <h1>Edit Location</h1>

    @if (Location == null)
    {
        <div class="alert alert-info">Loading...</div>
    }
    else
    {
        <EditForm Model="Location" OnValidSubmit="UpdateLocation" FormName="editLocation">
            @* We removed the DataAnnotationsValidator here so the address won't blink red *@

            <div class="mb-3">
                <label class="form-label">Location Name (Required)</label>
                <InputText @bind-Value="Location.Name" class="form-control" />
                @* We only show validation for the Name *@
                @if (string.IsNullOrWhiteSpace(Location.Name))
                {
                    <div class="text-danger">A location name is required.</div>
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Address (Optional)</label>
                <InputText @bind-Value="Location.Address" class="form-control" placeholder="Leave blank for Vans" />
                <div class="form-text">If left blank, a placeholder space will be used to satisfy the system.</div>
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox @bind-Value="Location.IsActive" class="form-check-input" id="activeCheck" />
                <label class="form-check-label" for="activeCheck">Is Active (Visible in Menus)</label>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a href="/locations" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private Location? Location;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Location = await context.Locations.FindAsync(Id);
    }

    private async Task UpdateLocation()
    {
        if (Location == null) return;

        using var context = await DbFactory.CreateDbContextAsync();
        
        // 1. If name is blank, don't save
        if (string.IsNullOrWhiteSpace(Location.Name)) return;

        // 2. THE HACK: If address is empty, give it a space string " " 
        // to bypass the [Required] attribute in your database model.
        if (string.IsNullOrWhiteSpace(Location.Address))
        {
            Location.Address = " "; 
        }

        context.Locations.Update(Location);
        await context.SaveChangesAsync();
        
        Navigation.NavigateTo("/locations");
    }
}