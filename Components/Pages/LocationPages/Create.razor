@code {
    [SupplyParameterFromForm] public LocationFormModel Form { get; set; } = new();

    private async Task CreateLocation()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        context.Locations.Add(new Location 
        { 
            Name = Form.Name, 
            Address = Form.Address, 
            Type = Form.Type 
        });
        await context.SaveChangesAsync();
        Navigation.NavigateTo("/Locations");
    }

    public class LocationFormModel
    {
        public string Name { get; set; } = "";
        public string Address { get; set; } = "";
        public LocationType Type { get; set; } = LocationType.Store;
    }
}</ApplicationDbContext>