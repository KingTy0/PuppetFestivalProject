@page "/Locations/create"
@using PuppetFestAPP.Web.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@rendermode InteractiveServer

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Create Location</MudText>

    <EditForm Model="Form" OnValidSubmit="CreateLocation">
        <DataAnnotationsValidator />
        <MudPaper Elevation="1" Class="pa-4">
            <MudStack Spacing="3">
              
                <MudTextField Label="Location Name" 
                              @bind-Value="Form.Name" 
                              Variant="Variant.Outlined" 
                              Immediate="true"
                              Required="true" />

                <MudTextField Label="Address" 
                              @bind-Value="Form.Address" 
                              Variant="Variant.Outlined" 
                              Immediate="true" />

                <MudSelect Label="Type" @bind-Value="Form.Type" Variant="Variant.Outlined">
                    @foreach (var type in Enum.GetValues<LocationType>())
                    {
                        <MudSelectItem Value="@type">@type</MudSelectItem>
                    }
                </MudSelect>

                <MudStack Row="true" Class="mt-4" Spacing="2">
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Create</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" href="/Locations">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </EditForm>
</MudContainer>

@code {
   
    public LocationFormModel Form { get; set; } = new();

    private async Task CreateLocation()
    {
        
        if (string.IsNullOrWhiteSpace(Form.Name)) return;

        using var context = await DbFactory.CreateDbContextAsync();
        
        var newLocation = new Location
        {
            Name = Form.Name,
            Address = Form.Address,
            Type = Form.Type
        };

        context.Locations.Add(newLocation);
        await context.SaveChangesAsync();
        Navigation.NavigateTo("/Locations");
    }

    public class LocationFormModel
    {
        public string Name { get; set; } = "";
        public string Address { get; set; } = "";
        public LocationType Type { get; set; } = LocationType.Store;
    }
}