@page "/products/delete/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = AppRoles.Admin + "," + AppRoles.InventoryManager)]
@rendermode InteractiveServer
@inject IDbContextFactory<PuppetFestAPP.Web.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Product</h2>
    <hr />
    @if (product is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">ParentProductId</dt>
            <dd class="col-sm-10">@product.ParentProductId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@product.Name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Description</dt>
            <dd class="col-sm-10">@product.Description</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Price</dt>
            <dd class="col-sm-10">@product.Price</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Size</dt>
            <dd class="col-sm-10">@product.Size</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Color</dt>
            <dd class="col-sm-10">@product.Color</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Material</dt>
            <dd class="col-sm-10">@product.Material</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">IsActive</dt>
            <dd class="col-sm-10">@product.IsActive</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">DateAdded</dt>
            <dd class="col-sm-10">@product.DateAdded</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ImageId</dt>
            <dd class="col-sm-10">@product.ImageId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">CategoryId</dt>
            <dd class="col-sm-10">@product.CategoryId</dd>
        </dl>
        <EditForm method="post" Model="product" OnValidSubmit="DeleteProduct" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(product is null)">Delete</button> |
            <a href="/products">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Product? product;

    [Parameter] // <--- CHANGE THIS
    public int Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        product = await context.Products.FirstOrDefaultAsync(m => m.Id == Id);

        if (product is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteProduct()
    {
        if (product is null) return;

        using var context = DbFactory.CreateDbContext();

        // 1. Capture the Parent ID before the product is gone
        var parentId = product.ParentProductId;

        // 2. Find it with inventory so it doesn't crash on foreign keys
        var productToDelete = await context.Products
        .Include(p => p.Inventories)
        .FirstOrDefaultAsync(p => p.Id == Id);

        if (productToDelete != null)
        {
            if (productToDelete.Inventories != null && productToDelete.Inventories.Any())
            {
                context.Inventories.RemoveRange(productToDelete.Inventories);
            }

            context.Products.Remove(productToDelete);
            await context.SaveChangesAsync();
        }

        // 3. Smart Redirect
        if (parentId.HasValue)
        {
            // Go back to the Master Product details
            NavigationManager.NavigateTo($"/products/details/{parentId.Value}");
        }
        else
        {
            // Go back to the main list
            NavigationManager.NavigateTo("/products");
        }
    }
}
