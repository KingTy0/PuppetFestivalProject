@page "/products/details/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@attribute [Authorize(Policy = AppPolicies.CanViewProducts)]
@inject IDbContextFactory<PuppetFestAPP.Web.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Product Details & Inventory</PageTitle>

<div class="container mt-4">
    <h1>Details</h1>

    @if (Product is null)
    {
        <div class="alert alert-warning">Loading product details...</div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <h2>Product Master Record</h2>
                <hr />
                <dl class="row">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Product.Name</dd>

                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@Product.Category?.Name</dd>

                    <dt class="col-sm-4">Base Price</dt>
                    <dd class="col-sm-8">@Product.Price.ToString("C")</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Product.IsActive ? "bg-success" : "bg-secondary")">
                            @(Product.IsActive ? "Active" : "Inactive")
                        </span>
                    </dd>
                </dl>
            </div>

            @* Master Product Image Display *@
            <div class="col-md-4 text-center">
                @if (!string.IsNullOrEmpty(Product.Image?.FileName))
                {
                    <img src="/images/products/@Product.Image.FileName" class="img-fluid rounded shadow"
                         style="max-height: 250px;" />
                }
                else
                {
                    <div class="p-5 border rounded bg-light text-muted">No Image</div>
                }
            </div>
        </div>

        <hr />
        <div class="d-flex justify-content-between align-items-center">
            <h3>Inventory Variants / Stock</h3>
            <AuthorizeView Policy="@AppPolicies.CanEditProducts">
                <Authorized>
                    <a href="@($"/products/create?parentId={Product.Id}")" class="btn btn-success btn-sm">+ Add New Variant</a>
                </Authorized>
            </AuthorizeView>
        </div>

        @if (InventoryItems.Any())
        {
            <table class="table table-hover mt-3 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Size</th>
                        <th>Color</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Location</th>
                        <th>Box Check</th>
                        <th>Delivery Check</th>
                        <AuthorizeView Policy="@AppPolicies.CanEditProducts">
                            <Authorized>
                                <th class="text-center">Actions</th>
                            </Authorized>
                        </AuthorizeView>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in InventoryItems)
                    {
                        <tr>
                            <td>@(v.Size == ProductSize.NA || v.Size == null ? "—" : v.Size.ToString())</td>
                            <td>@(v.Color == ProductColor.NA || v.Color == null ? "—" : v.Color.ToString())</td>
                            <td>@v.Price.ToString("C")</td>
                            <td>@GetStockTotal(v)</td>
                            <td>@GetLocations(v)</td>
                            <td>@GetBoxStatus(v)</td>
                            <td>@GetDeliveryStatus(v)</td>
                            <AuthorizeView Policy="@AppPolicies.CanEditProducts">
                                <Authorized>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a href="@($"/products/edit/{v.Id}")" class="btn btn-sm btn-outline-primary">
                                                Edit
                                            </a>
                                            <a href="@($"/products/delete/{v.Id}")" class="btn btn-sm btn-outline-danger">
                                                Delete
                                            </a>
                                        </div>
                                    </td>
                                </Authorized>
                            </AuthorizeView>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info mt-3">No inventory records are available for this product yet.</div>
        }

        <div class="mt-4">
            <AuthorizeView Policy="@AppPolicies.CanEditProducts">
                <Authorized>
                    <a href="@($"/products/edit/{Product.Id}")" class="btn btn-primary">Edit Master</a>
                    <span>|</span>
                </Authorized>
            </AuthorizeView>
            <a href="/products">Back to List</a>
        </div>
    }
</div>

