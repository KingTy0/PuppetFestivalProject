@page "/Locations"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using System.Linq
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar

<PageTitle>Locations</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2" Style="font-family: var(--title-font);">Locations</MudText>
<MudText Typo="Typo.body1" Class="mb-6">Details for the main hub, theaters, and vans can be viewed and edited here.</MudText>

<MudButton Color="Color.Primary" 
           Variant="Variant.Filled" 
           StartIcon="@Icons.Material.Filled.Add"
           href="/Locations/create" 
           FullWidth="true"
           Class="py-3 mb-6">
    CREATE NEW LOCATION
</MudButton>

@if (AllLocations == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    @* Main Location Section *@
    <MudExpansionPanels MultiExpansion="true" Class="mb-4">
        <MudExpansionPanel Text="@($"Main Location ({MainLocations.Count()})")" IsExpanded="true">
            <MudList T="string">
                @foreach (var loc in MainLocations)
                {
                    <MudListItem>
                        <div class="d-flex align-center justify-space-between w-100">
                            <div>
                                <MudText Typo="Typo.subtitle1"><b>@loc.Name</b></MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@loc.Address</MudText>
                            </div>
                            <div class="d-flex">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                        Variant="Variant.Filled" 
                                        Color="Color.Default" 
                                        Class="mr-2" 
                                        href="@($"/locations/edit/{loc.Id}")" />

                            <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                        Variant="Variant.Filled" 
                                        Color="Color.Error" 
                                        Class="mr-2" 
                                        OnClick="@(() => DeleteLocation(loc.Id))" />

                            <MudIconButton Icon="@Icons.Material.Filled.MenuBook" 
                                        Variant="Variant.Filled" 
                                        Color="Color.Default" 
                                        href="/inventory/stock" />
                        </div>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @* Theater Section *@
    <MudExpansionPanels MultiExpansion="true">
        <MudExpansionPanel Text="@($"Theater ({OtherLocations.Count()})")">
            <MudList T="string">
                @foreach (var loc in OtherLocations)
                {
                    <MudListItem>
                        <div class="d-flex align-center justify-space-between w-100">
                            <div>
                                <MudText Typo="Typo.subtitle1"><b>@loc.Name</b></MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@loc.Address</MudText>
                            </div>
                            <div class="d-flex">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                        Variant="Variant.Filled" 
                                        Color="Color.Default" 
                                        Class="mr-2" 
                                        href="@($"/locations/edit/{loc.Id}")" />

                            <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                        Variant="Variant.Filled" 
                                        Color="Color.Error" 
                                        Class="mr-2" 
                                        OnClick="@(() => DeleteLocation(loc.Id))" />

                            <MudIconButton Icon="@Icons.Material.Filled.MenuBook" 
                                        Variant="Variant.Filled" 
                                        Color="Color.Default" 
                                        href="/inventory/stock" />
                        </div>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        </MudExpansionPanel>
    </MudExpansionPanels>
}

@code {
    private List<Location>? AllLocations;

    
    private IEnumerable<Location> MainLocations => 
        AllLocations?.Where(l => l.Type == LocationType.Store) ?? Enumerable.Empty<Location>();

    private IEnumerable<Location> OtherLocations => 
        AllLocations?.Where(l => l.Type != LocationType.Store) ?? Enumerable.Empty<Location>();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        AllLocations = await db.Locations.ToListAsync();
    }

    private async Task DeleteLocation(int id)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var loc = await db.Locations.FindAsync(id);
        if (loc != null)
        {
            db.Locations.Remove(loc);
            await db.SaveChangesAsync();
            await LoadData(); // Refresh the UI
            Snackbar.Add("Location deleted", Severity.Info);
        }
    }
}