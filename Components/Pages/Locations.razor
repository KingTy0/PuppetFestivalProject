@code {
    private List<Location>? Locations;
    private string searchTerm = "";

    private IEnumerable<Location> FilteredLocations =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? Locations ?? Enumerable.Empty<Location>()
            : (Locations ?? Enumerable.Empty<Location>())
                .Where(l => l.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    PaginationState pagination = new() { ItemsPerPage = 20 };

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Locations = await context.Locations.ToListAsync();
    }
