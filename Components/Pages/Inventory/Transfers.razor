@code {
    private List<StockTransferBox> TransferBoxes = new();
    PaginationState pagination = new() { ItemsPerPage = 20 };

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        TransferBoxes = await context.StockTransferBoxes
            .Include(b => b.FromLocation)
            .Include(b => b.ToLocation)
            .Include(b => b.Items).ThenInclude(i => i.Product)
            .OrderByDescending(b => b.CreatedAt)
            .ToListAsync();
    }
}</StockTransferBox></ApplicationDbContext>