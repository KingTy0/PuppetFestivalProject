@page "/inventory/recount"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-10">
    @if (SelectedLocationId == null)
    {
        @* --- STEP 1: LOCATION SELECTION --- *@
        <div class="text-center">
            <MudText Typo="Typo.h3" Style="font-family: var(--title-font); font-weight: bold;">Inventory Recount</MudText>
            <MudText Typo="Typo.body1" Class="mt-4 mb-10" Color="Color.Secondary">
                Select your location and manually sync inventory by entering actual counted quantities to match what's in the system.
            </MudText>

            <MudText Align="Align.Left" Typo="Typo.subtitle1" Class="mb-2"><b>Select a location to continue:</b></MudText>
            <MudSelect T="int?" @bind-Value="DropdownValue"
           Variant="Variant.Outlined" 
           AnchorOrigin="Origin.BottomCenter"
           TransformOrigin="Origin.TopCenter">
    <MudSelectItem T="int?" Value="null">Select a location...</MudSelectItem>
    @foreach (var loc in Locations)
    {
        <MudSelectItem T="int?" Value="@((int?)loc.Id)">@loc.Name</MudSelectItem>
    }
</MudSelect>

           <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" 
           Size="Size.Large" Class="mt-8 py-3"
           Disabled="@(DropdownValue == null)"
           OnClick="ProceedToRecount"
           EndIcon="@Icons.Material.Filled.ArrowForward">
    CONTINUE
</MudButton>
        </div>
    }
    else if (!ShowSummary)
    {
        @* --- STEP 2: PHYSICAL COUNT LIST --- *@
        <MudLink OnClick="ResetLocation" Color="Color.Primary" Underline="Underline.None" Class="d-flex align-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="mr-1"/> BACK
        </MudLink>

        <MudText Typo="Typo.h4" Style="font-family: var(--title-font); font-weight: bold;">Inventory Recount</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Manually sync inventory by entering actual counted quantities to match what's in the system.
        </MudText>

        <MudChip T="string" Icon="@Icons.Material.Filled.TheaterComedy" Color="Color.Primary" Class="mb-6 px-4">
            @CurrentLocationName
        </MudChip>

        <div class="d-flex gap-2 mb-6">
            <MudTextField @bind-Value="SearchTerm" Placeholder="Search for an item" 
                          Variant="Variant.Filled" Adornment="Adornment.End" 
                          AdornmentIcon="@Icons.Material.Filled.Search" Margin="Margin.Dense" />
            <MudMenu EndIcon="@Icons.Material.Filled.FilterList"
         Label="Filter"
         Variant="Variant.Outlined"
         Size="Size.Small"
         Style="white-space:nowrap"
         AnchorOrigin="Origin.BottomCenter"
         TransformOrigin="Origin.TopCenter">
    <MudMenuItem OnClick="@(() => categoryFilter = null)">All</MudMenuItem>
    <MudMenuItem OnClick="@(() => categoryFilter = "Apparel")">Apparel</MudMenuItem>
    <MudMenuItem OnClick="@(() => categoryFilter = "Miscellaneous")">Miscellaneous</MudMenuItem>
    <MudDivider />
    <MudMenuItem OnClick="@(() => { categoryFilter = null; SearchTerm = ""; })">
        <MudIcon Icon="@Icons.Material.Filled.Clear" Size="Size.Small" Class="mr-1"/> Clear Filters
    </MudMenuItem>
</MudMenu>
        </div>

        @foreach (var parent in FilteredProducts)
        {
            <MudPaper Outlined="true" Class="mb-2 overflow-hidden">
                <MudExpansionPanel DisableGutters="true">
                    <TitleContent>
                        <div class="d-flex align-center py-2">
                            <MudAvatar Variant="Variant.Outlined" Square="true" Size="Size.Large" Class="mr-3">
                                <MudImage Src="@($"/Images/products/{parent.ImageFileName ?? "placeholder.png"}")" />
                            </MudAvatar>
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.body1"><b>@parent.ParentName</b></MudText>
                            </div>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <div class="pa-2 grey lighten-4 d-flex justify-space-between px-4">
                            <MudText Typo="Typo.caption"><b>Variation</b></MudText>
                            <div class="d-flex gap-4">
                                <MudText Typo="Typo.caption"><b>Inventory</b></MudText>
                                <MudText Typo="Typo.caption" Style="width: 60px;" Align="Align.Center"><b>Actual Amt</b></MudText>
                            </div>
                        </div>
                        <MudDivider />
                        @foreach (var v in parent.Variants)
                        {
                            <div class="d-flex align-center justify-space-between pa-4 border-bottom">
                                <MudText Typo="Typo.body2">@v.VariantName</MudText>
                                <div class="d-flex align-center gap-8">
                                    <MudText Typo="Typo.body2">@v.SystemQty</MudText>
                                    <div style="width: 80px;">
                                        <MudNumericField @bind-Value="v.ActualQty" Min="0" 
                                                       Margin="Margin.Dense" Variant="Variant.Outlined" />
                                    </div>
                                </div>
                            </div>
                        }
                    </ChildContent>
                </MudExpansionPanel>
            </MudPaper>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" 
                   Size="Size.Large" Class="mt-10 py-3" OnClick="() => ShowSummary = true">
            CONTINUE <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="ml-2"/>
        </MudButton>
    }
    else
    {
        @* --- STEP 3: RECOUNT SUMMARY --- *@
        <MudLink OnClick="() => ShowSummary = false" Color="Color.Primary" Underline="Underline.None" Class="d-flex align-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="mr-1"/> BACK
        </MudLink>

        <MudText Typo="Typo.h4" Style="font-family: var(--title-font); font-weight: bold;">
            <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="mr-2"/> Recount Summary
        </MudText>

        <MudChip T="string" Icon="@Icons.Material.Filled.TheaterComedy" Color="Color.Primary" Class="mt-4 mb-6">
            @CurrentLocationName
        </MudChip>

        <MudText Typo="Typo.subtitle1" Class="mb-4"><b>Remaining Inventory</b></MudText>

        @foreach (var parent in MasterProducts.Where(p => p.Variants.Any(v => v.ActualQty != v.SystemQty || v.ActualQty > 0)))
        {
            <MudPaper Class="pa-4 mb-3" Elevation="0" Style="background-color: #F5F5F5;">
                 <div class="d-flex align-center mb-2">
                    <MudAvatar Variant="Variant.Outlined" Square="true" Size="Size.Medium" Class="mr-4 bg-white">
                        <MudImage Src="@($"/Images/products/{parent.ImageFileName ?? "placeholder.png"}")" />
                    </MudAvatar>
                    <MudText Typo="Typo.body1"><b>@parent.ParentName</b></MudText>
                    <MudSpacer />
                    <MudChip T="string" Size="Size.Small">Total: @parent.Variants.Sum(v => v.ActualQty)</MudChip>
                </div>
                <MudDivider Class="my-2"/>
              @foreach(var v in parent.Variants)
{
    var delta = v.ActualQty - v.SystemQty;
    var deltaText = delta > 0 ? $"+{delta}" : delta.ToString();
    var deltaColor = delta > 0 ? "color: #4CAF50; font-weight: bold;" : delta < 0 ? "color: #F44336; font-weight: bold;" : "color: #9e9e9e;";
    <div class="d-flex justify-space-between align-center">
        <MudText Typo="Typo.caption">@v.VariantName</MudText>
        <div class="d-flex gap-3 align-center">
            <MudText Typo="Typo.caption" Style="color:#9e9e9e;">@v.ActualQty</MudText>
            <MudText Typo="Typo.caption" Style="@deltaColor">@deltaText</MudText>
        </div>
    </div>
}
            </MudPaper>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" 
                   Size="Size.Large" Class="mt-8 py-3" OnClick="SaveRecount">
            CONFIRM ADJUSTMENT
        </MudButton>
    }

    <MudMessageBox @ref="confirmBox" Title="@($"Record inventory adjustment at {CurrentLocationName}?")" 
               CancelText="Cancel">
    <MessageContent>
        This will update inventory to match your entered counts.
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary">Confirm</MudButton>
    </YesButton>
</MudMessageBox>

<MudMessageBox @ref="successBox" Title="Inventory Adjusted" CancelText="">
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary">OK</MudButton>
    </YesButton>
</MudMessageBox>

</MudContainer>

@code {
    private int? SelectedLocationId = null;
    private string SearchTerm = "";
    private bool ShowSummary = false;
    private string? categoryFilter = null;
    private int? DropdownValue = null;

    private MudMessageBox? confirmBox;
    private MudMessageBox? successBox;

    private List<Location> Locations = new();
    private List<RecountParentDTO> MasterProducts = new();

    private string CurrentLocationName => Locations.FirstOrDefault(l => l.Id == SelectedLocationId)?.Name ?? "";

  private IEnumerable<RecountParentDTO> FilteredProducts => MasterProducts
    .Where(p => string.IsNullOrEmpty(SearchTerm) || 
                p.ParentName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase))
    .Where(p => categoryFilter == null || p.CategoryName == categoryFilter);
    protected override async Task OnInitializedAsync()
{
    using var db = await DbFactory.CreateDbContextAsync();

    var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    var user = authState.User;
    var isFrontOfHouse = user.IsInRole("SalesStaff") && !user.IsInRole("Admin") && !user.IsInRole("InventoryManager");

    Locations = await db.Locations
        .Where(l => l.IsActive && l.Type != LocationType.Van)
        .OrderBy(l => l.Name)
        .ToListAsync();

   if (isFrontOfHouse)
{
    Locations = Locations.Where(l => l.Type == LocationType.Event).ToList();
    DropdownValue = Locations.FirstOrDefault()?.Id;
}
else
{
    var hub = Locations.FirstOrDefault(l => l.Type == LocationType.Store);
    DropdownValue = hub?.Id ?? Locations.FirstOrDefault()?.Id;
}
}

    private async Task ProceedToRecount()
{
    if (DropdownValue == null) return;
    SelectedLocationId = DropdownValue;
    await LoadProducts();
}

    private void ResetLocation() { SelectedLocationId = null; ShowSummary = false; }

    private async Task LoadProducts()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var stock = await db.ProductLocations
    .Include(pl => pl.Product).ThenInclude(p => p.Image)
    .Include(pl => pl.Product).ThenInclude(p => p.Category)
    .Include(pl => pl.Product).ThenInclude(p => p.ParentProduct!).ThenInclude(pp => pp.Image)
    .Include(pl => pl.Product).ThenInclude(p => p.ParentProduct!).ThenInclude(pp => pp.Category)
    .Where(pl => pl.LocationId == SelectedLocationId)
    .ToListAsync();

        MasterProducts = stock
            .GroupBy(s => s.Product.ParentProductId ?? s.Product.Id) 
            .Select(group => {
                var firstItem = group.First().Product;
                var isChild = firstItem.ParentProductId != null;
                return new RecountParentDTO {
                    ParentName = isChild ? (firstItem.ParentProduct?.Name ?? firstItem.Name) : firstItem.Name,
                    ImageFileName = isChild ? (firstItem.ParentProduct?.Image?.FileName ?? firstItem.Image?.FileName) : firstItem.Image?.FileName,
                    CategoryName = firstItem.Category?.Name ?? firstItem.ParentProduct?.Category?.Name,
                    Variants = group.Select(v => new RecountVariantDTO {
                        ProductId = v.ProductId,
                        VariantName = GenerateVariantName(v.Product),
                        SystemQty = v.Quantity,
                        ActualQty = v.Quantity // Default to system amount
                    }).OrderBy(v => v.VariantName).ToList()
                };
            }).OrderBy(p => p.ParentName).ToList();
    }

    private static string GenerateVariantName(Product p)
    {
        var parts = new List<string>();
        if (p.Size.HasValue && p.Size != ProductSize.NA) parts.Add(p.Size.ToString()!);
        if (p.Color.HasValue && p.Color != ProductColor.NA) parts.Add(p.Color.ToString()!);
        return parts.Any() ? string.Join(" / ", parts) : "Standard";
    }

   private async Task SaveRecount()
{
    bool? confirmed = await confirmBox!.ShowAsync();
    if (confirmed != true) return;

    using var db = await DbFactory.CreateDbContextAsync();
    foreach (var parent in MasterProducts)
    {
        foreach (var v in parent.Variants)
        {
            var stock = await db.ProductLocations.FirstOrDefaultAsync(pl => pl.ProductId == v.ProductId && pl.LocationId == SelectedLocationId);
            if (stock != null && stock.Quantity != v.ActualQty)
            {
                stock.Quantity = v.ActualQty;
                stock.LastUpdated = DateTime.UtcNow;
            }
        }
    }
    await db.SaveChangesAsync();

    await successBox!.ShowAsync();
    Navigation.NavigateTo("/inventory/stock");
}

    public class RecountParentDTO {
        public string ParentName { get; set; } = "";
        public string? ImageFileName { get; set; }
        public string? CategoryName { get; set; }
        public List<RecountVariantDTO> Variants { get; set; } = new();
    }

    public class RecountVariantDTO {
        public int ProductId { get; set; }
        public string VariantName { get; set; } = "";
        public int SystemQty { get; set; }
        public int ActualQty { get; set; }
    }
}