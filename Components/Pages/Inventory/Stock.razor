@page "/inventory/stock"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@using PuppetFestAPP.Web.Components

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@rendermode InteractiveServer

<style>
    .inventory-header {
        font-family: serif;
        font-weight: bold;
    }

    .location-summary-chip {
        background-color: rgba(93, 30, 33, 0.08);
        color: #5D1E21;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.03em;
    }

    .stock-card {
        border: 1px solid #eeeeee;
        border-radius: 10px;
        transition: box-shadow 0.15s ease;
    }

    .stock-card:hover {
        box-shadow: 0 2px 12px rgba(93, 30, 33, 0.08) !important;
    }

    .stock-avatar {
        height: 48px;
        width: 48px;
        background-color: #f5f5f5;
        border-radius: 6px;
        flex-shrink: 0;
    }

    .qty-chip-low {
        border-color: #F44336 !important;
        color: #F44336 !important;
    }

    .qty-chip-ok {
        border-color: #9e9e9e !important;
        color: #424242 !important;
    }

    .location-toolbar {
        padding: 12px 16px;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
    }

    .location-title {
        font-weight: 600;
        font-size: 0.95rem;
    }

    .location-meta {
        font-size: 0.78rem;
        color: #757575;
        margin-top: 1px;
    }

    .edit-qty-field {
        width: 80px;
    }
</style>

<MudStack Spacing="4" Class="pa-4">

    @* ── Page Header ── *@
    <div class="d-flex align-center justify-space-between flex-wrap gap-2">
        <MudText Typo="Typo.h4" Class="inventory-header">Inventory</MudText>
        <MudSwitch @bind-Value="_editMode"
                   Color="Color.Primary"
                   Label="Edit Mode"
                   LabelPosition="LabelPosition.Start" />
    </div>

    @* ── Location Filter ── *@
    <MudSelect T="Location"
               Label="Select a location"
               Variant="Variant.Outlined"
               @bind-Value="SelectedLocation"
               AnchorOrigin="Origin.BottomCenter">
        @foreach (var loc in AllLocations)
        {
            <MudSelectItem Value="@loc">@loc.Name</MudSelectItem>
        }
    </MudSelect>

    @* ── Content Area ── *@
    @if (SelectedLocation == null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Select a location to view inventory.
        </MudAlert>
    }
    else
    {
        var items = StockData
            .Where(x => x.LocationId == SelectedLocation.Id)
            .OrderBy(x => x.Product?.Name)
            .ToList();

        @* ── Location Summary Bar ── *@
        <div class="d-flex align-center gap-3 flex-wrap">
            <MudText Typo="Typo.body2" Style="color:#757575;">
                <b style="color:#212121;">@items.Count</b> SKUs &nbsp;·&nbsp;
                <b style="color:#212121;">@items.Sum(x => x.Quantity)</b> total units
            </MudText>
            @{
                var lowCount = items.Count(x => x.Quantity < 10);
            }
            @if (lowCount > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                    @lowCount low stock
                </MudChip>
            }
        </div>

        @if (!items.Any())
        {
            <MudPaper Class="pa-8 d-flex flex-column align-center justify-center"
                      Elevation="0"
                      Style="border: 1px dashed #ddd; border-radius: 10px;">
                <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                         Style="font-size:2.5rem; color:#bdbdbd; margin-bottom:8px;" />
                <MudText Typo="Typo.h6" Style="color:#616161;">No Inventory</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    No inventory exists at this location yet.
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudExpansionPanels MultiExpansion="true" Elevation="0">
                @foreach (var pl in items)
                {
                    <MudExpansionPanel Class="stock-card mb-2" Elevation="0">
                        <TitleContent>
                            <div class="d-flex align-center gap-3 w-100 pr-2">

                                @* Product image placeholder *@
                                <MudAvatar Square="true" Class="stock-avatar">
                                    <MudIcon Icon="@Icons.Material.Filled.Image"
                                             Style="color:#bdbdbd;" />
                                </MudAvatar>

                                @* Product info *@
                                <div class="flex-grow-1" style="min-width:0;">
                                    <MudText Typo="Typo.body1"
                                             Style="font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                        @pl.Product?.Name
                                    </MudText>
                                    <MudText Typo="Typo.caption" Style="color:#757575;">
                                        @pl.Product?.Size / @pl.Product?.Color
                                    </MudText>
                                </div>

                                @* Quantity: edit mode vs read mode *@
                                @if (_editMode)
                                {
                                    <MudNumericField T="int"
                                                     Value="@pl.Quantity"
                                                     ValueChanged="@(val => OnQuantityChanged(pl, val))"
                                                     Variant="Variant.Outlined"
                                                     Margin="Margin.Dense"
                                                     Class="edit-qty-field"
                                                     HideSpinButtons="true" />
                                }
                                else
                                {
                                    <MudChip T="int"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small"
                                             Class="@(pl.Quantity < 10 ? "qty-chip-low" : "qty-chip-ok")">
                                        @pl.Quantity
                                    </MudChip>
                                }

                                <MudIconButton Icon="@Icons.Material.Filled.MoreHoriz"
                                               Size="Size.Small"
                                               Style="color:#9e9e9e;" />
                            </div>
                        </TitleContent>

                        @* Expansion detail panel *@
                        <ChildContent>
                            <div class="pa-3 pt-0">
                                <MudDivider Class="mb-3" />
                                <MudStack Row="true" Spacing="4" Class="flex-wrap">
                                    <div>
                                        <MudText Typo="Typo.caption" Style="color:#9e9e9e; text-transform:uppercase; letter-spacing:.05em;">Size</MudText>
                                        <MudText Typo="Typo.body2">@(pl.Product?.Size.ToString() ?? "—")</MudText>
                                    </div>
                                    <div>
                                        <MudText Typo="Typo.caption" Style="color:#9e9e9e; text-transform:uppercase; letter-spacing:.05em;">Color</MudText>
                                        <MudText Typo="Typo.body2">@(pl.Product?.Color.ToString() ?? "—")</MudText>
                                    </div>
                                    <div>
                                        <MudText Typo="Typo.caption" Style="color:#9e9e9e; text-transform:uppercase; letter-spacing:.05em;">Quantity</MudText>
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">@pl.Quantity</MudText>
                                    </div>
                                </MudStack>
                            </div>
                        </ChildContent>
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
    }
</MudStack>

@code {
    private List<ProductLocation> StockData = new();
    private List<Location> AllLocations = new();
    private Location? SelectedLocation;
    private bool _editMode = false;

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();

        AllLocations = await db.Locations
            .OrderBy(l => l.Name)
            .ToListAsync();

        StockData = await db.ProductLocations
            .Include(pl => pl.Product)
            .Include(pl => pl.Location)
            .Where(pl => pl.Quantity > 0)
            .OrderBy(pl => pl.Location.Name)
            .ThenBy(pl => pl.Product.Name)
            .ToListAsync();

        SelectedLocation = AllLocations.FirstOrDefault();
    }

    private async Task OnQuantityChanged(ProductLocation item, int newVal)
    {
        var parameters = new DialogParameters
        {
            { "ProductName", item.Product?.Name ?? "Unknown Product" },
            { "AdjustedValue", newVal }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<QuantityConfirmDialog>("Confirm Change", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            item.Quantity = newVal;

            using var db = await DbFactory.CreateDbContextAsync();
            var dbItem = await db.ProductLocations.FindAsync(item.Id);
            if (dbItem != null)
            {
                dbItem.Quantity = newVal;
                await db.SaveChangesAsync();
            }
        }
    }
}
