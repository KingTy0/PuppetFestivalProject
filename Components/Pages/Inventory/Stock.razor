@page "/inventory/stock"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@using PuppetFestAPP.Web.Components

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@rendermode InteractiveServer

<style>
    .inventory-header { font-family: serif; font-weight: bold; }
    .stock-card { border: 1px solid #eeeeee; border-radius: 10px; transition: box-shadow 0.15s ease; }
    .stock-card:hover { box-shadow: 0 2px 12px rgba(93, 30, 33, 0.08) !important; }
    .stock-avatar { height: 48px; width: 48px; background-color: #f5f5f5; border-radius: 6px; flex-shrink: 0; }
    .qty-chip-low { border-color: #F44336 !important; color: #F44336 !important; }
    .qty-chip-ok { border-color: #9e9e9e !important; color: #424242 !important; }
    .edit-qty-field { width: 80px; }
    .border-bottom { border-bottom: 1px solid #e0e0e0; }
</style>

<MudContainer MaxWidth="MaxWidth.Medium">

    @* ── Content Area ── *@
    @if (SelectedLocation == null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Select a location to view inventory.
        </MudAlert>
    }
    else
    {
        var grouped = GetGroupedStock(SelectedLocation.Id);
        var totalUnits = grouped.Sum(g => g.Variants.Sum(v => v.Quantity));
        var lowCount = grouped.Sum(g => g.Variants.Count(v => InventoryAlerts.IsLowStock(v.Quantity)));

        @* ── Summary Bar ── *@
        <div class="d-flex align-center gap-3 flex-wrap">
            <MudText Typo="Typo.body2" Style="color:#757575;">
                <b style="color:#212121;">@grouped.Count</b> products &nbsp;·&nbsp;
                <b style="color:#212121;">@totalUnits</b> total units
            </MudText>
            <MudSwitch @bind-Value="_editMode"
                    Color="Color.Primary"
                    Label="Edit Mode"
                    LabelPosition="LabelPosition.Start" />
        </div>

        @* ── Location Filter ── *@
        <MudSelect T="Location"
                Label="Select a location"
                Variant="Variant.Outlined"
                @bind-Value="SelectedLocation"
                AnchorOrigin="Origin.BottomCenter"
                TransformOrigin="Origin.TopCenter">
            @foreach (var loc in AllLocations)
            {
                <MudSelectItem Value="@loc">@loc.Name</MudSelectItem>
            }
        </MudSelect>

        @* ── Content Area ── *@
        @if (SelectedLocation == null)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                Select a location to view inventory.
            </MudAlert>
        }
        else
        {
            var grouped = GetGroupedStock(SelectedLocation.Id);
            var totalUnits = grouped.Sum(g => g.Variants.Sum(v => v.Quantity));
            var lowCount = grouped.Sum(g => g.Variants.Count(v => v.Quantity < 10));

            @* ── Summary Bar ── *@
            <div class="d-flex align-center gap-3 flex-wrap">
                <MudText Typo="Typo.body2" Style="color:#757575;">
                    <b style="color:#212121;">@grouped.Count</b> products &nbsp;·&nbsp;
                    <b style="color:#212121;">@totalUnits</b> total units
                </MudText>
                @if (lowCount > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                        @lowCount low stock
                    </MudChip>
                }
            </div>

            @if (!grouped.Any())
            {
                <MudPaper Class="pa-8 d-flex flex-column align-center justify-center"
                        Elevation="0"
                        Style="border: 1px dashed #ddd; border-radius: 10px;">
                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                            Style="font-size:2.5rem; color:#bdbdbd; margin-bottom:8px;" />
                    <MudText Typo="Typo.h6" Style="color:#616161;">No Inventory</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        No products exist yet.
                    </MudText>
                </MudPaper>
            }
            else
            {
                <MudExpansionPanels MultiExpansion="true" Elevation="0">
                    @foreach (var group in grouped)
                    {
                        <MudExpansionPanel Class="stock-card mb-2" Elevation="0">
                            <TitleContent>
                                <div class="d-flex align-center gap-3 w-100 pr-2">
                                    @* Parent image *@
                                    <MudAvatar Square="true" Class="stock-avatar">
                                        @if (!string.IsNullOrEmpty(group.ImageFileName))
                                        {
                                            <MudImage Src="@($"/images/products/{group.ImageFileName}")" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Image" Style="color:#bdbdbd;" />
                                        }
                                    </MudAvatar>

                                    @* Parent name and total *@
                                    <div class="flex-grow-1" style="min-width:0;">
                                        <MudText Typo="Typo.body1"
                                                Style="font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                            @group.ParentName
                                        </MudText>
                                        <MudText Typo="Typo.caption" Style="color:#757575;">
                                            @group.Variants.Count variant(s) · @group.Variants.Sum(v => v.Quantity) total
                                        </MudText>
                                    </div>

                                    @* Low stock badge if any variant is low *@
                                    @if (group.Variants.Any(v => v.Quantity < 10))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                            Low
                                        </MudChip>
                                    }
                                </div>
                            </TitleContent>

                            <ChildContent>
                                <MudDivider />
                                @* Column headers *@
                                <div class="pa-2 d-flex justify-space-between px-4" style="background:#fafafa;">
                                    <MudText Typo="Typo.caption"><b>Variant</b></MudText>
                                    <MudText Typo="Typo.caption"><b>Quantity</b></MudText>
                                </div>
                                <MudDivider />

                                @* Low stock badge if any variant is low *@
                                @if (group.Variants.Any(v => InventoryAlerts.IsLowStock(v.Quantity)))
                                {
                                    <div class="d-flex align-center justify-space-between pa-3 border-bottom">
                                        <MudText Style="width: 90%;">
                                            <p class="body-2">@variant.VariantName</p>
                                        </MudText>

                                        @if (_editMode)
                                        {
                                            <MudNumericField T="int"
                                                            Value="@variant.Quantity"
                                                            ValueChanged="@(val => OnQuantityChanged(variant.StockRecord, val))"
                                                            Variant="Variant.Outlined"
                                                            Margin="Margin.Dense"
                                                            Class="edit-qty-field"
                                                            HideSpinButtons="true" 
                                                            Style="max-width: 100px;" />
                                        }
                                        else
                                        {
                                            <MudChip T="int"
                                                    Variant="Variant.Outlined"
                                                    Size="Size.Small"
                                                    Class="@(variant.Quantity < 10 ? "qty-chip-low" : "qty-chip-ok")">
                                                @variant.Quantity
                                            </MudChip>
                                        }
                                    </div>
                                }
                            </div>
                        </TitleContent>

                        <ChildContent>
                            <MudDivider />
                            @* Column headers *@
                            <div class="pa-2 d-flex justify-space-between px-4" style="background:#fafafa;">
                                <MudText Typo="Typo.caption"><b>Variant</b></MudText>
                                <MudText Typo="Typo.caption"><b>Quantity</b></MudText>
                            </div>
                            <MudDivider />

                            @foreach (var variant in group.Variants)
                            {
                                <div class="d-flex align-center justify-space-between pa-3 border-bottom">
                                    <MudText Typo="Typo.body2">@variant.VariantName</MudText>

                                    @if (_editMode)
                                    {
                                        <MudNumericField T="int"
                                                         Value="@variant.Quantity"
                                                         ValueChanged="@(val => OnQuantityChanged(variant.StockRecord, val))"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Class="edit-qty-field"
                                                         HideSpinButtons="true" />
                                    }
                                    else
                                    {
                                        <MudChip T="int"
                                                 Variant="Variant.Outlined"
                                                 Size="Size.Small"
                                                 Class="@(InventoryAlerts.IsLowStock(variant.Quantity) ? "qty-chip-low" : "qty-chip-ok")">
                                            @variant.Quantity
                                        </MudChip>
                                    }
                                </div>
                            }
                        </ChildContent>
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
    </MudStack>

</MudContainer>



@code {
    private List<ProductLocation> StockData = new();
    private List<Location> AllLocations = new();
    private Location? SelectedLocation;
    private bool _editMode = false;

    // ── DTOs ──
    public class StockGroupDTO
    {
        public string ParentName { get; set; } = "";
        public string? ImageFileName { get; set; }
        public List<StockVariantDTO> Variants { get; set; } = new();
    }

    public class StockVariantDTO
    {
        public string VariantName { get; set; } = "";
        public int Quantity { get; set; }
        public ProductLocation StockRecord { get; set; } = null!;
    }

    protected override async Task OnInitializedAsync()
{
    using var db = await DbFactory.CreateDbContextAsync();

    AllLocations = await db.Locations
        .Where(l => l.IsActive && l.Type != LocationType.Van)
        .OrderBy(l => l.Name)
        .ToListAsync();

    StockData = await db.ProductLocations
        .Include(pl => pl.Product)
            .ThenInclude(p => p.Image)
        .Include(pl => pl.Product)
            .ThenInclude(p => p.ParentProduct!)
                .ThenInclude(pp => pp.Image)
        .Include(pl => pl.Location)
        .Where(pl => pl.Quantity > 0)
        .OrderBy(pl => pl.Location.Name)
        .ThenBy(pl => pl.Product.Name)
        .ToListAsync();

    SelectedLocation = AllLocations.FirstOrDefault(l => l.Type == LocationType.Store) 
                   ?? AllLocations.FirstOrDefault();
}

    private List<StockGroupDTO> GetGroupedStock(int locationId)
    {
        return StockData
            .Where(x => x.LocationId == locationId)
            // Only show variant products (those with a parent) OR standalone products (no parent, no children)
            .Where(x => x.Product?.ParentProductId != null || 
                        !StockData.Any(s => s.Product?.ParentProductId == x.ProductId))
            .GroupBy(x => x.Product?.ParentProductId ?? x.ProductId)
            .Select(g => {
                var first = g.First().Product;
                var isChild = first?.ParentProductId != null;
                var imageFile = isChild
                    ? (first?.ParentProduct?.Image?.FileName ?? first?.Image?.FileName)
                    : first?.Image?.FileName;
                var parentName = isChild
                    ? (first?.ParentProduct?.Name ?? first?.Name ?? "Unknown")
                    : (first?.Name ?? "Unknown");

                return new StockGroupDTO
                {
                    ParentName = parentName,
                    ImageFileName = imageFile,
                    Variants = g.Select(v => new StockVariantDTO
                    {
                        VariantName = GenerateVariantName(v.Product!),
                        Quantity = v.Quantity,
                        StockRecord = v
                    }).OrderBy(v => v.VariantName).ToList()
                };
            })
            .OrderBy(g => g.ParentName)
            .ToList();
    }

    private static string GenerateVariantName(Product p)
    {
        var parts = new List<string>();
        if (p.Size.HasValue && p.Size != ProductSize.NA) parts.Add(p.Size.ToString()!);
        if (p.Color.HasValue && p.Color != ProductColor.NA) parts.Add(p.Color.ToString()!);
        return parts.Any() ? string.Join(" / ", parts) : "Standard";
    }

    private async Task OnQuantityChanged(ProductLocation item, int newVal)
    {
        var parameters = new DialogParameters
        {
            { "ProductName", item.Product?.Name ?? "Unknown Product" },
            { "AdjustedValue", newVal }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<QuantityConfirmDialog>("Confirm Change", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            item.Quantity = newVal;

            using var db = await DbFactory.CreateDbContextAsync();
            var dbItem = await db.ProductLocations
                .FirstOrDefaultAsync(pl => pl.ProductId == item.ProductId
                                        && pl.LocationId == item.LocationId);

            if (dbItem != null)
            {
                dbItem.Quantity = newVal;
                dbItem.LastUpdated = DateTime.UtcNow;
            }
            else
            {
                db.ProductLocations.Add(new ProductLocation
                {
                    ProductId = item.ProductId,
                    LocationId = item.LocationId,
                    Quantity = newVal,
                    LastUpdated = DateTime.UtcNow
                });
            }

            await db.SaveChangesAsync();
        }
    }
}