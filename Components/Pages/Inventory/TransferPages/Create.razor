@page "/inventory/transfer/create"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Create Transfer Box</PageTitle>

<div class="container mt-4">
    <h1>Create Transfer Box</h1>
    
    <EditForm Model="Form" OnValidSubmit="CreateTransfer" FormName="transferBox" Enhance>
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">From Location (Source)</label>
                @* Changed to use the OnFromLocationChanged sensor *@
                <InputSelect TValue="int?" 
                             Value="Form.FromLocationId" 
                             ValueChanged="OnFromLocationChanged" 
                             ValueExpression="() => Form.FromLocationId" 
                             class="form-control">
                    <option value="0">Select Source...</option>
                    @foreach (var loc in Locations.Where(l => l.IsActive))
                    {
                        <option value="@loc.Id">@loc.Name (@loc.Type)</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">To Location (Destination)</label>
                <InputSelect @bind-Value="Form.ToLocationId" class="form-control">
                    <option value="0">Select Destination...</option>
                    @foreach (var loc in Locations.Where(l => l.IsActive))
                    {
                        <option value="@loc.Id">@loc.Name (@loc.Type)</option>
                    }
                </InputSelect>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Notes (optional)</label>
            <InputTextArea @bind-Value="Form.Notes" class="form-control" rows="2" />
        </div>

        @if (Form.Items.Any())
        {
            <h4>Box Items</h4>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Form.Items)
                    {
                        <tr>
                            <td>@GetProductName(item.ProductId)</td>
                            <td>@item.Quantity</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-danger" @onclick="() => Form.Items.Remove(item)">
                                    Remove
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="row border p-3 bg-light rounded">
            <div class="col-md-6 mb-3">
                <label class="form-label">Add Product</label>
                @* Changed to use the OnProductSelected sensor *@
                <InputSelect TValue="int?" 
                             Value="selectedProductId" 
                             ValueChanged="OnProductSelected" 
                             ValueExpression="() => selectedProductId" 
                             class="form-control">
                    <option value="0">Select Product...</option>
                    @foreach (var prod in Products)
                    {
                        <option value="@prod.Id">@prod.Name @(prod.Size != ProductSize.NA ? $"({prod.Size})" : "")</option>
                    }
                </InputSelect>

                @if (selectedProductId > 0)
                {
                    <div class="form-text text-primary">In stock here: <strong>@maxAvailable</strong></div>
                }
                
                <InputNumber @bind-Value="selectedQuantity" class="form-control mt-2" placeholder="Quantity" />
                
                @if (selectedQuantity > maxAvailable)
                {
                    <div class="text-danger fw-bold small">Error: You only have @maxAvailable available!</div>
                }

                <button type="button" class="btn btn-outline-secondary mt-2" 
                        @onclick="AddItem" 
                        disabled="@(selectedProductId == null || selectedQuantity <= 0 || selectedQuantity > maxAvailable)">
                    Add to Box
                </button>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary" disabled="@(!Form.IsValid())">
                Create Transfer Box
            </button>
            <a href="/inventory" class="btn btn-secondary">Cancel</a>
        </div>
    </EditForm>
</div>

@code {
    [SupplyParameterFromForm] public TransferBoxFormModel Form { get; set; } = new();
    private int? selectedProductId;
    private int selectedQuantity;
    private int maxAvailable; // Tracks actual stock for the selected product

    private List<Location> Locations = new();
    private List<Product> Products = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Locations = await context.Locations.Where(l => l.IsActive).ToListAsync();
        // We no longer load all products here. We wait for a location to be picked.
    }

    private async Task OnFromLocationChanged(int? newLocationId)
    {
        Form.FromLocationId = newLocationId;
        Form.Items.Clear(); // Clear the box if the source location changes
        selectedProductId = null;
        maxAvailable = 0;

        if (newLocationId.HasValue && newLocationId > 0)
        {
            using var context = await DbFactory.CreateDbContextAsync();
            
            // Only pull products that actually have a record at this specific location with Qty > 0
            Products = await context.ProductLocations
                .Where(pl => pl.LocationId == newLocationId && pl.Quantity > 0)
                .Include(pl => pl.Product)
                .Select(pl => pl.Product!)
                .ToListAsync();
        }
        else
        {
            Products.Clear();
        }
    }

    private async Task OnProductSelected(int? productId)
    {
        selectedProductId = productId;
        if (productId.HasValue && productId > 0 && Form.FromLocationId.HasValue)
        {
            using var context = await DbFactory.CreateDbContextAsync();
            // Find the exact quantity sitting at the 'From' location
            maxAvailable = await context.ProductLocations
                .Where(pl => pl.LocationId == Form.FromLocationId && pl.ProductId == productId)
                .Select(pl => pl.Quantity)
                .FirstOrDefaultAsync();
        }
        else
        {
            maxAvailable = 0;
        }
    }

    private void AddItem()
    {
        if (selectedProductId.HasValue && selectedQuantity > 0 && selectedQuantity <= maxAvailable)
        {
            Form.Items.Add(new TransferBoxItemModel 
            { 
                ProductId = selectedProductId.Value, 
                Quantity = selectedQuantity 
            });
            selectedProductId = null;
            selectedQuantity = 0;
            maxAvailable = 0;
        }
    }

    private string GetProductName(int productId)
    {
        // Check the filtered list first, then query database if needed (fallback)
        var prod = Products.FirstOrDefault(p => p.Id == productId);
        return prod?.Name ?? "Selected Item";
    }

    private async Task CreateTransfer()
    {
        if (!Form.FromLocationId.HasValue || !Form.ToLocationId.HasValue || !Form.Items.Any()) return;

        using var context = await DbFactory.CreateDbContextAsync();
        using var transaction = await context.Database.BeginTransactionAsync();

        try
        {
            var transferBox = new StockTransferBox 
            { 
                FromLocationId = Form.FromLocationId.Value,
                ToLocationId = Form.ToLocationId.Value,
                Notes = Form.Notes
            };
            context.StockTransferBoxes.Add(transferBox);
            await context.SaveChangesAsync();

          foreach (var item in Form.Items)
        {
           
            context.StockTransferBoxItems.Add(new StockTransferBoxItem
            {
                StockTransferBoxId = transferBox.Id,
                ProductId = item.ProductId,
                Quantity = item.Quantity
            });

           
            var fromStock = await context.ProductLocations
                .FirstOrDefaultAsync(pl => pl.ProductId == item.ProductId && pl.LocationId == Form.FromLocationId.Value);
            
            if (fromStock != null)
            {
                fromStock.Quantity -= item.Quantity;
                
                fromStock.LastUpdated = DateTime.UtcNow; 
            }
            
           
        }
            
            await context.SaveChangesAsync();
            await transaction.CommitAsync();
            Navigation.NavigateTo("/inventory");
        }
        catch
        {
            await transaction.RollbackAsync();
            throw;
        }
    }

    public class TransferBoxFormModel
    {
        public int? FromLocationId { get; set; }
        public int? ToLocationId { get; set; }
        public string? Notes { get; set; }
        public List<TransferBoxItemModel> Items { get; set; } = new();
        public bool IsValid() => FromLocationId.HasValue && ToLocationId.HasValue && Items.Any();
    }

    public class TransferBoxItemModel
    {
        public int ProductId { get; set; }
        public int Quantity { get; set; }
    }
}