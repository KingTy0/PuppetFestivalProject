@page "/inventory/transfer/create"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<style>
    /* 1. Ensure the popover container isn't 0px tall */
    .mud-popover-content {
        min-height: 100px !important;
        min-width: 200px !important;
        background-color: white !important;
        color: black !important;
        box-shadow: 0px 10px 30px rgba(0,0,0,0.5) !important;
        display: block !important;
        visibility: visible !important;
        opacity: 1 !important;
        z-index: 999999 !important;
    }

    /* 2. Fix the .NET 9 Layout 'Clip' */
    main, .mud-main-content, .mud-container {
        overflow: visible !important;
    }

    /* 3. Make the actual list items visible */
    .mud-list-item {
        display: flex !important;
        visibility: visible !important;
        opacity: 1 !important;
    }
</style>

<PageTitle>Create Transfer Box</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Create Transfer Box</MudText>

    <EditForm Model="Form" OnValidSubmit="CreateTransfer">
        <DataAnnotationsValidator />
     
        <MudGrid>
            @* ── Locations Section ── *@
            <MudItem xs="12" md="6">
        
        <MudSelect T="int?" Label="From Location (Source)" 
                   Value="Form.FromLocationId" 
                   ValueChanged="OnFromLocationChanged" 
                   ValueExpression="() => Form.FromLocationId" 
                   Variant="Variant.Outlined" 
                   AnchorOrigin="Origin.BottomCenter" 
                   TransformOrigin="Origin.TopCenter" 
                   Fixed="true"> 
            <MudSelectItem T="int?" Value="null">Select Source...</MudSelectItem>
            @foreach (var loc in Locations)
            {
                <MudSelectItem T="int?" Value="@loc.Id">@loc.Name (@loc.Type)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>

    <MudItem xs="12" md="6">
        
        <MudSelect T="int?" Label="To Location (Destination)" 
                   @bind-Value="Form.ToLocationId" 
                   Variant="Variant.Outlined"
                   AnchorOrigin="Origin.BottomCenter" 
                   TransformOrigin="Origin.TopCenter" 
                   Fixed="true">
            <MudSelectItem T="int?" Value="null">Select Destination...</MudSelectItem>
            @foreach (var loc in Locations)
            {
                <MudSelectItem T="int?" Value="@loc.Id">@loc.Name (@loc.Type)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>

            <MudItem xs="12">
                <MudTextField Label="Notes (optional)" @bind-Value="Form.Notes" Lines="2" Variant="Variant.Outlined" />
            </MudItem>

            @* ── Current Box Items ── *@
            @if (Form.Items.Any())
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mt-4">Box Items</MudText>
                    <MudTable Items="Form.Items" Dense="true" Hover="true">
                        <HeaderContent>
                            <MudTh>Product</MudTh>
                            <MudTh>Quantity</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate Context="item">
                            <MudTd>@GetProductName(item.ProductId)</MudTd>
                            <MudTd>@item.Quantity</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="() => Form.Items.Remove(item)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
            }

            @* ── Add Product Section ── *@
            <MudItem xs="12">
                <MudPaper Elevation="1" Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6">Add Product</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="8">
                            <MudSelect T="int?" Label="Select Product" Value="selectedProductId" ValueChanged="OnProductSelected" ValueExpression="() => selectedProductId">
                                <MudSelectItem T="int?" Value="null">Select Product...</MudSelectItem>
                                @foreach (var prod in Products)
                                {
                                    <MudSelectItem T="int?" Value="@prod.Id">@prod.Name @(prod.Size != ProductSize.NA ? $"({prod.Size})" : "")</MudSelectItem>
                                }
                            </MudSelect>
                            @if (selectedProductId > 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Primary">In stock here: @maxAvailable</MudText>
                            }
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudNumericField @bind-Value="selectedQuantity" Label="Quantity" Min="1" Max="maxAvailable" />
                        </MudItem>
                    </MudGrid>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Class="mt-3" 
                               OnClick="AddItem" 
                               Disabled="@(selectedProductId == null || selectedQuantity <= 0 || selectedQuantity > maxAvailable)">
                        Add to Box
                    </MudButton>
                </MudPaper>
            </MudItem>

            @* ── Form Actions ── *@
            <MudItem xs="12" Class="mt-6">
                <MudStack Row="true" Spacing="2">
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!Form.IsValid())">
                        Create Transfer Box
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/inventory">Cancel</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>

@code {
    public TransferBoxFormModel Form { get; set; } = new();
    private int? selectedProductId;
    private int selectedQuantity;
    private int maxAvailable;
    private List<Location> Locations = new();
    private List<Product> Products = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Locations = await context.Locations.Where(l => l.IsActive).ToListAsync();
    }

    private async Task OnFromLocationChanged(int? newLocationId)
    {
        Form.FromLocationId = newLocationId;
        Form.Items.Clear();
        selectedProductId = null;
        maxAvailable = 0;

        if (newLocationId.HasValue && newLocationId > 0)
        {
            using var context = await DbFactory.CreateDbContextAsync();
            Products = await context.ProductLocations
                .Where(pl => pl.LocationId == newLocationId && pl.Quantity > 0)
                .Include(pl => pl.Product)
                .Select(pl => pl.Product!)
                .ToListAsync();
        }
        else
        {
            Products.Clear();
        }
    }

    private async Task OnProductSelected(int? productId)
    {
        selectedProductId = productId;
        if (productId.HasValue && productId > 0 && Form.FromLocationId.HasValue)
        {
            using var context = await DbFactory.CreateDbContextAsync();
            maxAvailable = await context.ProductLocations
                .Where(pl => pl.LocationId == Form.FromLocationId && pl.ProductId == productId)
                .Select(pl => pl.Quantity)
                .FirstOrDefaultAsync();
        }
        else
        {
            maxAvailable = 0;
        }
    }

    private void AddItem()
    {
        if (selectedProductId.HasValue && selectedQuantity > 0 && selectedQuantity <= maxAvailable)
        {
            Form.Items.Add(new TransferBoxItemModel { ProductId = selectedProductId.Value, Quantity = selectedQuantity });
            selectedProductId = null;
            selectedQuantity = 0;
            maxAvailable = 0;
        }
    }

    private string GetProductName(int productId) => Products.FirstOrDefault(p => p.Id == productId)?.Name ?? "Selected Item";

    private async Task CreateTransfer()
    {
        if (!Form.FromLocationId.HasValue || !Form.ToLocationId.HasValue || !Form.Items.Any()) return;

        using var context = await DbFactory.CreateDbContextAsync();
        using var transaction = await context.Database.BeginTransactionAsync();
        try
        {
            var transferBox = new StockTransferBox { 
                FromLocationId = Form.FromLocationId.Value, 
                ToLocationId = Form.ToLocationId.Value, 
                Notes = Form.Notes 
            };
            context.StockTransferBoxes.Add(transferBox);
            await context.SaveChangesAsync();

            foreach (var item in Form.Items)
            {
                context.StockTransferBoxItems.Add(new StockTransferBoxItem { 
                    StockTransferBoxId = transferBox.Id, 
                    ProductId = item.ProductId, 
                    Quantity = item.Quantity 
                });

                var fromStock = await context.ProductLocations
                    .FirstOrDefaultAsync(pl => pl.ProductId == item.ProductId && pl.LocationId == Form.FromLocationId.Value);
                
                if (fromStock != null)
                {
                    fromStock.Quantity -= item.Quantity;
                    fromStock.LastUpdated = DateTime.UtcNow;
                }
            }
            await context.SaveChangesAsync();
            await transaction.CommitAsync();
            Navigation.NavigateTo("/inventory");
        }
        catch
        {
            await transaction.RollbackAsync();
            throw;
        }
    }

    public class TransferBoxFormModel
    {
        public int? FromLocationId { get; set; }
        public int? ToLocationId { get; set; }
        public string? Notes { get; set; }
        public List<TransferBoxItemModel> Items { get; set; } = new();
        public bool IsValid() => FromLocationId.HasValue && ToLocationId.HasValue && Items.Any() && FromLocationId != ToLocationId;
    }

    public class TransferBoxItemModel
    {
        public int ProductId { get; set; }
        public int Quantity { get; set; }
    }
}
