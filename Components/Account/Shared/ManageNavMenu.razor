@using Microsoft.AspNetCore.Identity
@using PuppetFestAPP.Web.Data

@inject SignInManager<ApplicationUser> SignInManager

<MudNavMenu>
    <MudNavLink Href="Account/Manage/Email" 
                EndIcon="@Icons.Material.Filled.ArrowForward"
                FullWidth="true"
                class="my-2">
        Email
    </MudNavLink>
    <MudDivider></MudDivider>
    <MudNavLink Href="Account/Manage/PhoneNumber" 
                EndIcon="@Icons.Material.Filled.ArrowForward"
                FullWidth="true"
                class="my-2">
        Phone Number
    </MudNavLink>
    <MudDivider></MudDivider>
    <MudNavLink Href="Account/Manage/ChangePassword" 
                EndIcon="@Icons.Material.Filled.ArrowForward"
                FullWidth="true"
                class="my-2">
        Password
    </MudNavLink>

    @* @if (hasExternalLogins)
    {
        <MudNavLink Href="Account/Manage/ExternalLogins">External logins</MudNavLink>
    }
    <MudNavLink Href="Account/Manage/TwoFactorAuthentication">Two-factor authentication</MudNavLink>
    <MudNavLink Href="Account/Manage/PersonalData">Personal data</MudNavLink> *@
</MudNavMenu>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}
