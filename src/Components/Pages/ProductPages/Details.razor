@page "/products/details/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Medium" Class="pa-4">
    @* --- HEADER NAVIGATION --- *@
    <div class="d-flex align-center justify-space-between mb-2">

        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               Variant="Variant.Text"
               Color="Color.Default"
               Size="Size.Large"
               Class="mb-2 text-uppercase"
               Href="/products">
        Back
    </MudButton>
        
        @if (Product != null)
        {
            <div class="d-flex gap-2">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" 
                               Href="@($"/products/edit/{Product.Id}")" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" 
                               Href="@($"/products/delete/{Product.Id}")" />
            </div>
        }
    </div>

    @if (Product is null)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else
    {
        @* --- PRODUCT TITLE --- *@
        <MudText Class="my-3">
            <h3>@Product.Name</h3>
        </MudText>

        @* --- PRODUCT IMAGE --- *@
        <div class="d-flex justify-center mb-8">
            <MudPaper Elevation="0" Outlined="true" Class="pa-4 d-flex justify-center align-center" Style="width: 100%; max-width: 300px; height: 300px;">
                @if (!string.IsNullOrEmpty(Product.Image?.FileName))
                {
                    <MudImage Src="@($"/images/products/{Product.Image.FileName}")" 
                              ObjectFit="ObjectFit.Contain" Height="250" Width="250" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Size="Size.Large" Color="Color.Transparent" />
                }
            </MudPaper>
        </div>

        @* --- BASE INFO --- *@
        <MudText Class="mb-1">
            <p class="body-1">@Product.Category?.Name</p>
        </MudText>
        <MudText Class="mb-1">
            <p class="body-1">@Product.Price.ToString("C")</p>
        </MudText>

        @* --- VARIATIONS SECTION --- *@
        
        <div class="d-flex align-center justify-space-between mb-4">
            <MudText Class="my-3">
                <h3>Sizes</h3>
            </MudText>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Medium" 
                       Variant="Variant.Text" Color="Color.Primary"
                       Href="@($"/products/create?parentId={Product.Id}")">
                Add Variant
            </MudButton>
        </div>

        @if (Variants != null && Variants.Any())
        {
            <div class="d-flex flex-wrap gap-2 mb-10">
                @foreach (var v in Variants)
                {
                    <MudChip T="string" Variant="Variant.Filled" Color="Color.Default" 
                             Class="px-6 py-4" OnClick="@(() => NavigationManager.NavigateTo($"/products/edit/{v.Id}"))">
                        @(v.Size == ProductSize.NA || v.Size == null ? "Standard" : GetFriendlySize(v.Size.Value))
                    </MudChip>
                }
            </div>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-10">
                Standalone product. No variations added yet.
            </MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(Product.Description))
        {
            <MudText Class="mb-1">
                <p class="subtitle-1"><strong>Description</strong></p>
            </MudText>
            <MudText>
                <p class="body-1">@Product.Description</p>
            </MudText>
        }
    }
</MudContainer>

@code {
    [Parameter] public int Id { get; set; }
    private Product? Product { get; set; }
    private List<Product> Variants { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        Product = await context.Products
            .Include(p => p.Category)
            .Include(p => p.Image)
            .FirstOrDefaultAsync(m => m.Id == Id);

        if (Product is not null)
        {
            Variants = await context.Products
                .Where(p => p.ParentProductId == Id)
                .OrderBy(p => p.Size)
                .ToListAsync();
        }
    }

    private string GetFriendlySize(ProductSize size) => size switch
    {
        ProductSize.S => "Small",
        ProductSize.M => "Medium",
        ProductSize.L => "Large",
        ProductSize.XL => "X-Large",
        ProductSize.XXL => "XX-Large",
        ProductSize.XXXL => "XXX-Large",
        _ => size.ToString()
    };
}