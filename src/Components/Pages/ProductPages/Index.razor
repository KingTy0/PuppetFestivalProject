@page "/products"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Medium">

    <MudText Class="my-3">
        <h1>Product Catalog</h1>
    </MudText>

    <MudText Class="mb-6">
        <p class="body-1">The collection of merchandise currently being sold.</p>
    </MudText>

    <MudDivider Class="mb-2"></MudDivider>

    <MudButton Href="products/create"
                StartIcon="@Icons.Material.Filled.Add"
                Variant="Variant.Filled" 
                Color="Color.Primary"
                FullWidth="true"
                Size="Size.Large"
                Class="mb-5">
        CREATE A PRODUCT
    </MudButton>

    <MudDivider Class="mb-2"></MudDivider>

    @* --- SEARCH & FILTER --- *@
    <div class="d-flex gap-2 mb-4">
        <MudTextField @bind-Value="searchTerm"
                      Placeholder="Search for an item"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Style="flex:1" />

        <MudMenu StartIcon="@Icons.Material.Filled.FilterList"
                 Label="Filter"
                 Variant="Variant.Outlined"
                 Size="Size.Large"
                 Style="white-space:nowrap"
                 AnchorOrigin="Origin.BottomCenter"
                 TransformOrigin="Origin.TopCenter">
            <MudMenuItem OnClick="@(() => selectedCategory = null)">All</MudMenuItem>
            <MudMenuItem OnClick="@(() => selectedCategory = "Apparel")">Apparel</MudMenuItem>
            <MudMenuItem OnClick="@(() => selectedCategory = "Miscellaneous")">Miscellaneous</MudMenuItem>
            <MudDivider />
            <MudMenuItem OnClick="ClearFilters">
                <MudIcon Icon="@Icons.Material.Filled.Clear" Size="Size.Small" Class="mr-1"/>
                Clear Filters
            </MudMenuItem>
        </MudMenu>
    </div>

    @* Active filter chip *@
    @if (selectedCategory != null)
    {
        <div class="mb-3">
            <MudChip T="string" Color="Color.Primary" Size="Size.Small"
                     OnClose="@(() => selectedCategory = null)">
                @selectedCategory
            </MudChip>
        </div>
    }

    @* --- PRODUCT LIST --- *@
    <MudPaper Elevation="0" Outlined="true" Class="overflow-hidden">
        <div class="d-flex pa-3 grey lighten-4 border-bottom">
            <div  Class="width: 75% flex-grow-1">
                <MudText><p class="body-2"><b>Product Name</b></p></MudText>
            </div>
            <div  Class="width: 25%; text-right;">
                <MudText><p class="body-2"><b>Category</b></p></MudText>
            </div>
            
        </div>

        @if (!FilteredProducts.Any())
        {
            <div class="pa-8 d-flex flex-column align-center justify-center">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" Class="mb-2" />
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                    No products found
                </MudText>
            </div>
        }

        @foreach (var prod in FilteredProducts)
        {
            <div class="product-row d-flex align-center pa-3 border-bottom clickable"
                 @onclick="@(() => NavigateToDetails(prod.Id))">
                <MudAvatar Variant="Variant.Outlined" Square="true" Size="Size.Large" Class="mr-3 bg-white">
                    @if (prod.Image != null)
                    {
                        <MudImage Src="@($"/images/products/{prod.Image.FileName}")" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Color="Color.Transparent" />
                    }
                </MudAvatar>

                <div class="width: 75% flex-grow-1">
                    <MudText>
                        <p class="body-2">@prod.Name</p>
                    </MudText>
                </div>

                <div style="width: 25%" class="text-right">
                    <MudText>
                        <p class="body-2">@prod.Category?.Name</p>
                    </MudText>
                </div>
            </div>
        }
    </MudPaper>
</MudContainer>

<style>
    .product-row:nth-child(even) { background-color: #f9f9f9; }
    .product-row:hover { background-color: #f0f0f0; cursor: pointer; }
    .border-bottom { border-bottom: 1px solid #e0e0e0; }
</style>

@code {
    private List<Product> Products = new();
    private string searchTerm = "";
    private string? selectedCategory = null;

    private IEnumerable<Product> FilteredProducts => Products
        .Where(p => string.IsNullOrWhiteSpace(searchTerm) ||
                    p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(p => selectedCategory == null ||
                    p.Category?.Name == selectedCategory);

    private void NavigateToDetails(int id) => Nav.NavigateTo($"/products/details/{id}");

    private void ClearFilters()
    {
        searchTerm = "";
        selectedCategory = null;
    }

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        Products = await db.Products
            .Include(p => p.Category)
            .Include(p => p.Image)
            .Where(p => p.ParentProductId == null)
            .OrderBy(p => p.Name)
            .ToListAsync();
    }
}