@page "/products/create"
@page "/products/create/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>@(parentId.HasValue ? "Create Variant" : "Create Product")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="pa-4">

    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               Variant="Variant.Text"
               Color="Color.Default"
               Size="Size.Large"
               Class="mb-2 text-uppercase"
               Href="/products">
        Back
    </MudButton>

    <MudText Class="my-3">
        <h1>@(parentId.HasValue ? "Create Variant" : "Product Manager")</h1>
    </MudText>

    <EditForm Model="Form" OnValidSubmit="AddProduct" FormName="createProduct">
        <DataAnnotationsValidator />

        <input type="hidden" @bind="Form.ParentProductId" />

        <MudText Typo="Typo.subtitle1" Style="font-weight: 700; margin-bottom: 12px;">
            Product Details<sup style="color: var(--mud-palette-primary);">*</sup>
        </MudText>

        <MudSelect T="int"
                   @bind-Value="Form.CategoryId"
                   Placeholder="Select Category"
                   Variant="Variant.Outlined"
                   Class="mb-3"
                   FullWidth="true"
                   AnchorOrigin="Origin.BottomLeft"
                   TransformOrigin="Origin.TopLeft">
            <MudSelectItem T="int" Value="0">-- Select Category --</MudSelectItem>
            @foreach (var cat in Categories)
            {
                <MudSelectItem T="int" Value="@cat.Id">@cat.Name</MudSelectItem>
            }
        </MudSelect>

        <MudTextField @bind-Value="Form.Name"
                      Placeholder="Product Name*"
                      Variant="Variant.Outlined"
                      Class="mb-3"
                      FullWidth="true"
                      For="() => Form.Name" />

        <MudTextField @bind-Value="Form.Description"
                      Placeholder="Product Description (optional)"
                      Variant="Variant.Outlined"
                      Class="mb-4"
                      FullWidth="true"
                      Lines="2" />

        <MudText Typo="Typo.subtitle1" Style="font-weight: 700; margin-bottom: 12px;">
            Price
        </MudText>

        <MudNumericField @bind-Value="Form.Price"
                         Placeholder="Input Price"
                         Variant="Variant.Outlined"
                         Class="mb-4"
                         FullWidth="true"
                         HideSpinButtons="true"
                         For="() => Form.Price" />

        <MudText Typo="Typo.subtitle1" Style="font-weight: 700; margin-bottom: 12px;">
            Select Available Sizes:
        </MudText>

        <MudGrid Spacing="0" Class="mb-4">
            @foreach (var size in Enum.GetValues<ProductSize>())
            {
                <MudItem xs="6">
        <MudCheckBox T="bool"
                     Value="@Form.SelectedSizes.Contains(size)"
                     ValueChanged="@(v => OnSizeToggled(size, v))"
                     Label="@size.ToString()"
                     Color="Color.Primary"
                     Size="Size.Small" />
        </MudItem>
            }
        </MudGrid>

        

        <MudText Typo="Typo.subtitle1" Style="font-weight: 700; margin-bottom: 12px;">
            Images
        </MudText>

        <MudPaper Outlined="true" Class="pa-4 mb-3" Style="border-radius: 8px;">
    @if (!string.IsNullOrEmpty(imagePreviewBase64))
    {
        <MudImage Src="@imagePreviewBase64"
                  Height="150"
                  ObjectFit="ObjectFit.Contain"
                  Style="border-radius: 8px; margin-bottom: 8px; width: 100%;" />
        <MudText Typo="Typo.caption" Color="Color.Success" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" /> 
            Image ready!
        </MudText>
    }
    else
    {
        <MudText Typo="Typo.body2" Style="margin-bottom: 8px; color: #aaa;">
            Upload Image Here
        </MudText>
    }

    @if (isUploading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
        <MudText Typo="Typo.caption" Color="Color.Info">Uploading...</MudText>
    }
</MudPaper>

        <MudStack Row="true" Spacing="2" Class="mb-6">
            <label for="filePickerInput">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Style="pointer-events: none; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.08em;"
                           StartIcon="@Icons.Material.Filled.FolderOpen">
                    Open File Picker
                </MudButton>
            </label>
            <InputFile id="filePickerInput" OnChange="LoadFiles" style="display:none;" />

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       Size="Size.Small"
                       Style="text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.08em;"
                       Disabled="@(string.IsNullOrEmpty(uploadedFileName) || isUploading)">
                Upload
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       Size="Size.Small"
                       Style="text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.08em;"
                       OnClick="ClearImage"
                       Disabled="@string.IsNullOrEmpty(uploadedFileName)">
                Clear
            </MudButton>
        </MudStack>

        <ValidationSummary class="text-danger" />

        <MudDivider Class="mb-4" />
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Default"
                       Size="Size.Large"
                       Href="/products">
                Cancel
            </MudButton>

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       Disabled="@isUploading"
                       StartIcon="@Icons.Material.Filled.Check">
                Confirm
            </MudButton>
        </MudStack>

    </EditForm>
</MudContainer>

@code {
    
    public ProductFormModel Form { get; set; } = new();

    [SupplyParameterFromQuery]
    public int? parentId { get; set; }

    private List<Category> Categories = new();
    private bool isUploading = false;
    private string? uploadedFileName;
    private string? previewImageUrl;

    private string? imagePreviewBase64;

    [Parameter]
    public int Id { get; set; }

   protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Categories = await context.Categories.ToListAsync();

        if (parentId.HasValue && parentId > 0)
        {
            var parent = await context.Products
                .Include(p => p.Image)
                .FirstOrDefaultAsync(p => p.Id == parentId);

            if (parent != null)
            {
                Form.Name = parent.Name;
                Form.Description = parent.Description;
                Form.Price = parent.Price;
                Form.CategoryId = parent.CategoryId;
                Form.ImageId = parent.ImageId;

                if (parent.Image != null)
                {
                    previewImageUrl = $"/images/products/{parent.Image.FileName}";
                }
            }
        }
    }

private void OnSizeToggled(ProductSize size, bool isChecked)
{
    if (size == ProductSize.NA && isChecked)
    {
        
        Form.SelectedSizes.Clear();
        Form.SelectedSizes.Add(ProductSize.NA);
    }
    else if (isChecked)
    {
        
        Form.SelectedSizes.Remove(ProductSize.NA);
        if (!Form.SelectedSizes.Contains(size)) Form.SelectedSizes.Add(size);
    }
    else
    {
        Form.SelectedSizes.Remove(size);
    }
}



  private async Task LoadFiles(InputFileChangeEventArgs e)
{
    var file = e.File;
    if (file != null)
    {
        isUploading = true;
        StateHasChanged();

        using var memoryStream = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 10).CopyToAsync(memoryStream);
        var bytes = memoryStream.ToArray();

        var mimeType = file.ContentType;
        imagePreviewBase64 = $"data:{mimeType};base64,{Convert.ToBase64String(bytes)}";

        var tempName = $"{Guid.NewGuid()}{Path.GetExtension(file.Name)}";
        var tempPath = Path.Combine(Path.GetTempPath(), "puppetfest_uploads", tempName);
        Directory.CreateDirectory(Path.GetDirectoryName(tempPath)!);
        await System.IO.File.WriteAllBytesAsync(tempPath, bytes);

        uploadedFileName = tempName;

        isUploading = false;
        StateHasChanged();
    }
}

    private void ClearImage()
{
    uploadedFileName = null;
    Form.ImageFileName = null;
    imagePreviewBase64 = null;
}

  private async Task AddProduct()
{
    using var context = await DbFactory.CreateDbContextAsync();
    Product? parentProduct = null;

    if (parentId.HasValue && parentId > 0)
    {
        parentProduct = await context.Products.FindAsync(parentId.Value);
    }

    if (parentProduct == null)
    {
        parentProduct = new Product {
            Name = Form.Name,
            Price = Form.Price,
            Description = Form.Description ?? "",
            CategoryId = Form.CategoryId,
            Size = ProductSize.NA, 
            Color = ProductColor.NA,
            IsActive = true,
            DateAdded = DateTime.Now
        };
        context.Products.Add(parentProduct);
        await context.SaveChangesAsync(); 
    }
    else 
    {
        parentProduct.Price = Form.Price;
        parentProduct.Description = Form.Description;
        await context.SaveChangesAsync();
    }

   
    if (!string.IsNullOrEmpty(uploadedFileName))
    {
        var tempPath = Path.Combine(Path.GetTempPath(), "puppetfest_uploads", uploadedFileName);
        var finalPath = Path.Combine(Environment.WebRootPath, "images", "products", uploadedFileName);

        if (System.IO.File.Exists(tempPath))
        {
            
            Directory.CreateDirectory(Path.GetDirectoryName(finalPath)!);
            
          
            System.IO.File.Move(tempPath, finalPath); 
            
           
           var newImage = new PuppetFestAPP.Web.Models.Image
            {
                FileName = uploadedFileName,
                AltText = Form.Name
            };
            context.Images.Add(newImage);
            await context.SaveChangesAsync(); 
            
           
            parentProduct.ImageId = newImage.Id;
            await context.SaveChangesAsync();
        }
    }

 
    if (Form.SelectedSizes.Any())
{
    var sizes = Form.SelectedSizes.Where(s => s != ProductSize.NA).ToList();
    if (!sizes.Any()) sizes.Add(ProductSize.NA);

    foreach (var s in sizes)
    {
        bool exists = await context.Products.AnyAsync(p =>
            p.ParentProductId == parentProduct.Id && p.Size == s);

        if (!exists)
        {
            context.Products.Add(new Product
            {
                Name = $"{parentProduct.Name} ({s})",
                ParentProductId = parentProduct.Id,
                Price = Form.Price,
                CategoryId = parentProduct.CategoryId,
                Size = s,
                Color = ProductColor.NA,
                ImageId = parentProduct.ImageId,
                Description = parentProduct.Description,
                IsActive = true,
                DateAdded = DateTime.Now
            });
        }
    }
    await context.SaveChangesAsync();
}

    Snackbar.Add("Changes saved successfully!", Severity.Success);
    NavigationManager.NavigateTo($"/products/details/{parentProduct.Id}");
}


}
