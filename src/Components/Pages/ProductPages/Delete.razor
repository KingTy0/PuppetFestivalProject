@page "/Products/delete/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IWebHostEnvironment WebHostEnvironment

<PageTitle>Delete Product</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Delete Product</MudText>

    @if (Product is null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-4">
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
                Are you sure you want to delete this product?
            </MudAlert>

            <MudSimpleTable Style="overflow-x: auto;">
                <tbody>
                    <tr><td><strong>Name</strong></td><td>@Product.Name</td></tr>
                    <tr><td><strong>Price</strong></td><td>@Product.Price.ToString("C")</td></tr>
                    <tr><td><strong>Size</strong></td><td>@Product.Size</td></tr>
                    <tr><td><strong>Color</strong></td><td>@Product.Color</td></tr>
                    <tr><td><strong>Material</strong></td><td>@Product.Material</td></tr>
                </tbody>
            </MudSimpleTable>

            <MudStack Row="true" Class="mt-6" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteProduct">
                    Permanently Delete
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/Products">
                    Cancel
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private Product? Product;

    [Parameter]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Product = await context.Products.FirstOrDefaultAsync(m => m.Id == Id);

        if (Product is null)
        {
            NavigationManager.NavigateTo("/Products");
        }
    }

    private async Task DeleteProduct()
{
    using var context = await DbFactory.CreateDbContextAsync();
    
    var productToDelete = await context.Products
        .Include(p => p.Inventories)
        .Include(p => p.Image)        
        .FirstOrDefaultAsync(p => p.Id == Id);

    if (productToDelete != null)
    {
        var imageFileName = productToDelete.Image?.FileName;
        var imageId = productToDelete.ImageId;
        var isParent = productToDelete.ParentProductId == null;

        try 
        {
            var variants = await context.Products
                .Where(v => v.ParentProductId == productToDelete.Id)
                .Include(v => v.Inventories)
                .ToListAsync();

            foreach (var variant in variants)
            {
                if (variant.Inventories != null && variant.Inventories.Any())
                {
                    context.Inventories.RemoveRange(variant.Inventories);
                }
                context.Products.Remove(variant);
            }

            if (productToDelete.Inventories != null && productToDelete.Inventories.Any())
            {
                context.Inventories.RemoveRange(productToDelete.Inventories);
            }

            context.Products.Remove(productToDelete);
            
            await context.SaveChangesAsync();

            if (isParent && imageId != null && !string.IsNullOrEmpty(imageFileName))
            {
                var imagePath = Path.Combine(WebHostEnvironment.WebRootPath, "images", "products", imageFileName);
                if (System.IO.File.Exists(imagePath))
                    System.IO.File.Delete(imagePath);

                var imageRecord = await context.Images.FindAsync(imageId);
                if (imageRecord != null)
                {
                    context.Images.Remove(imageRecord);
                    await context.SaveChangesAsync();
                }
            }

            NavigationManager.NavigateTo("/products");
        }
        catch (Exception ex)
        {
            var innerMessage = ex.InnerException?.Message ?? ex.Message;
            Console.WriteLine($"DATABASE REJECTED DELETE: {innerMessage}");
            Snackbar.Add($"Cannot delete: {innerMessage}", MudBlazor.Severity.Error);
        }
    }
}

}
