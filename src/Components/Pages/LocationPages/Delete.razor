@page "/Locations/delete/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Delete Location</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Delete Location</MudText>

    @if (Location == null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-4">
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
                Are you sure you want to delete this?
            </MudAlert>

            <MudText Typo="Typo.body1"><strong>Name:</strong> @Location.Name</MudText>
            <MudText Typo="Typo.body1" Class="mb-4"><strong>Address:</strong> @Location.Address</MudText>

            @if (HasDependencies)
            {
                <MudAlert Severity="Severity.Warning" Class="mt-4">
                    <strong>Cannot Delete:</strong> This location has stock or transfer records. 
                    Deactivate it instead of deleting.
                </MudAlert>
            }

            <MudStack Row="true" Class="mt-6" Spacing="2">
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Error" 
                           OnClick="ConfirmDelete" 
                           Disabled="@HasDependencies">
                    Permanently Delete
                </MudButton>
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Secondary" 
                           Href="/Locations">
                    Cancel
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter] public int Id { get; set; }
    private Location? Location;
    private bool HasDependencies;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Location = await context.Locations.FindAsync(Id);

        if (Location != null)
        {
            var stockCount = await context.ProductLocations.AnyAsync(pl => pl.LocationId == Id);
            var transferCount = await context.StockTransferBoxes.AnyAsync(b => b.FromLocationId == Id || b.ToLocationId == Id);
            HasDependencies = stockCount || transferCount;
        }
    }

    private async Task ConfirmDelete()
    {
        if (HasDependencies) return;

        using var context = await DbFactory.CreateDbContextAsync();
        var loc = await context.Locations.FindAsync(Id);
        if (loc != null)
        {
            context.Locations.Remove(loc);
            await context.SaveChangesAsync();
        }
        Navigation.NavigateTo("/Locations");
    }
}
