@page "/Locations"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using System.Linq
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar

<PageTitle>Locations</PageTitle>


<MudContainer MaxWidth="MaxWidth.Medium">

    <MudText Class="my-3">
        <h1>Locations</h1>
    </MudText>

    <MudText Class="mb-6">
        <p class="body-1">Details for the main hub, theaters, and vans can be viewed and edited here.</p>
    </MudText>

    <MudDivider Class="mb-2"></MudDivider>

    <MudButton Href="/Locations/create" 
                StartIcon="@Icons.Material.Filled.Add"
                Variant="Variant.Filled" 
                Color="Color.Primary"
                FullWidth="true"
                Size="Size.Large"
                Class="mb-5">
        CREATE NEW LOCATION
    </MudButton>

    <MudDivider Class="mb-2"></MudDivider>

    @if (AllLocations == null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        @* Main Hub Section — Store type only, always just the one hub *@
        <MudExpansionPanels MultiExpansion="true" Class="mb-4">
            <MudExpansionPanel Text="@($"Main Hub ({HubLocations.Count()})")" Expanded="true">
                <MudList T="string">
                    @foreach (var loc in HubLocations)
                    {
                        <MudListItem>
                            <div class="d-flex align-center justify-space-between w-100">
                                <div>
                                    <MudText>
                                        <p><strong>@loc.Name</strong></p>
                                    </MudText>
                                    <MudText Color="Color.Secondary">
                                        <p class="body-2">@loc.Address</p>
                                    </MudText>
                                </div>
                                <div class="d-flex">
                                    <MudTooltip Text="Edit Location">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    Class="mr-2"
                                                    href="@($"/locations/edit/{loc.Id}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete Location">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    Class="mr-2"
                                                    OnClick="@(() => DeleteLocation(loc.Id))" />
                                    </MudTooltip>
                                    <MudTooltip Text="View Inventory">
                                        <MudIconButton Icon="@Icons.Material.Filled.MenuBook"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    href="/inventory/stock" />
                                    </MudTooltip>
                                </div>
                            </div>
                        </MudListItem>
                        <MudDivider />
                    }
                </MudList>
            </MudExpansionPanel>

            <MudExpansionPanel Text="@($"Theaters ({TheaterLocations.Count()})")" Expanded="true">
                <MudList T="string">
                    @foreach (var loc in TheaterLocations)
                    {
                        <MudListItem>
                            <div class="d-flex align-center justify-space-between w-100">
                                <div>
                                    <MudText>
                                        <p><strong>@loc.Name</strong></p>
                                    </MudText>
                                    <MudText Color="Color.Secondary">
                                        <p class="body-2">@loc.Address</p>
                                    </MudText>
                                </div>
                                <div class="d-flex">
                                    <MudTooltip Text="Edit Location">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    Class="mr-2"
                                                    href="@($"/locations/edit/{loc.Id}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete Location">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    Class="mr-2"
                                                    OnClick="@(() => DeleteLocation(loc.Id))" />
                                    </MudTooltip>
                                    <MudTooltip Text="View Inventory">
                                        <MudIconButton Icon="@Icons.Material.Filled.MenuBook"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    href="/inventory/stock" />
                                    </MudTooltip>
                                </div>
                            </div>
                        </MudListItem>
                        <MudDivider />
                    }
                </MudList>
            </MudExpansionPanel>

            <MudExpansionPanel Text="@($"Warehouse ({WarehouseLocations.Count()})")" Expanded="true">
                <MudList T="string">
                    @foreach (var loc in WarehouseLocations)
                    {
                        <MudListItem>
                            <div class="d-flex align-center justify-space-between w-100">
                                <div>
                                    <MudText>
                                        <p><strong>@loc.Name</strong></p>
                                    </MudText>
                                    <MudText Color="Color.Secondary">
                                        <p class="body-2">@loc.Address</p>
                                    </MudText>
                                </div>
                                <div class="d-flex">
                                    <MudTooltip Text="Edit Location">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    Class="mr-2"
                                                    href="@($"/locations/edit/{loc.Id}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete Location">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    Class="mr-2"
                                                    OnClick="@(() => DeleteLocation(loc.Id))" />
                                    </MudTooltip>
                                    <MudTooltip Text="View Inventory">
                                        <MudIconButton Icon="@Icons.Material.Filled.MenuBook"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    href="/inventory/stock" />
                                    </MudTooltip>
                                </div>
                            </div>
                        </MudListItem>
                        <MudDivider />
                    }
                </MudList>
            </MudExpansionPanel>

            <MudExpansionPanel Text="@($"Vans ({VanLocations.Count()})")" Expanded="true">
                <MudList T="string">
                    @foreach (var loc in VanLocations)
                    {
                        <MudListItem>
                            <div class="d-flex align-center justify-space-between w-100">
                                <div>
                                    <MudText>
                                        <p><strong>@loc.Name</strong></p>
                                    </MudText>
                                    <MudText Color="Color.Secondary">
                                        <p class="body-2">@loc.Address</p>
                                    </MudText>
                                </div>
                                <div class="d-flex">
                                    <MudTooltip Text="Edit Location">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    Class="mr-2"
                                                    href="@($"/locations/edit/{loc.Id}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete Location">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    Class="mr-2"
                                                    OnClick="@(() => DeleteLocation(loc.Id))" />
                                    </MudTooltip>
                                    <MudTooltip Text="View Inventory">
                                        <MudIconButton Icon="@Icons.Material.Filled.MenuBook"
                                                    Variant="Variant.Filled"
                                                    Color="Color.Default"
                                                    href="/inventory/stock" />
                                    </MudTooltip>
                                </div>
                            </div>
                        </MudListItem>
                        <MudDivider />
                    }
                </MudList>
            </MudExpansionPanel>
            
        </MudExpansionPanels>
    }

</MudContainer>



@code {
    private List<Location>? AllLocations;

    private IEnumerable<Location> HubLocations =>
        AllLocations?.Where(l => l.Type == LocationType.Store) ?? Enumerable.Empty<Location>();

    private IEnumerable<Location> TheaterLocations =>
        AllLocations?.Where(l => l.Type == LocationType.Event) ?? Enumerable.Empty<Location>();

    private IEnumerable<Location> VanLocations =>
        AllLocations?.Where(l => l.Type == LocationType.Van) ?? Enumerable.Empty<Location>();

            private IEnumerable<Location> WarehouseLocations =>
    AllLocations?.Where(l => l.Type == LocationType.Warehouse) ?? Enumerable.Empty<Location>();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        AllLocations = await db.Locations.ToListAsync();
    }

    private async Task DeleteLocation(int id)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var loc = await db.Locations.FindAsync(id);
        if (loc != null)
        {
            db.Locations.Remove(loc);
            await db.SaveChangesAsync();
            await LoadData();
            Snackbar.Add("Location deleted", Severity.Info);
        }
    }
}